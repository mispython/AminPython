//EIBWFCFD JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=128M                    JOB24159
/*JOBPARM S=S1M1
//*
//DELETE  EXEC PGM=IEFBR14
//DEL01    DD DSN=SAP.PBB.FCYFD.FCYFDFTP,
//            DISP=(MOD,DELETE,DELETE),
//            SPACE=(CYL,(0))
//*
//CREATE  EXEC PGM=IEFBR14
//CRT01    DD DSN=SAP.PBB.FCYFD.FCYFDFTP,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FB,LRECL=80,BLKSIZE=24000),
//            SPACE=(CYL,(100,100),RLSE),UNIT=(SYSDA,5)
//*
//EIBWFCFD  EXEC SAS609
//DPTRBL    DD DSN=RBP2.B033.DPTRBLGS,DISP=SHR
//DEPOSIT   DD DSN=SAP.PBB.MNITB(0),DISP=SHR
//MNIFD     DD DSN=SAP.PBB.MNIFD(0),DISP=SHR
//FCYFD     DD DSN=SAP.PBB.FCYFD,DISP=SHR
//MISMTD    DD DSN=SAP.PBB.MTD.SASDATA,DISP=SHR
//SIGNA     DD DSN=SAP.PBB.SMS.SIGNATUR,DISP=SHR
//DEPO      DD DSN=SAP.PBB.FCFD,DISP=OLD
//TEMP      DD DSN=&&TEMP,DISP=(NEW,DELETE,DELETE),
//             DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//             SPACE=(CYL,(100,50)),UNIT=(SYSDA,5)
//PGM       DD DSN=SAP.BNM.PROGRAM,DISP=SHR
//SYSIN     DD *
OPTIONS YEARCUTOFF=1950;
*;
%INC PGM(PBBDPFMT);

DATA REPTDATE (KEEP=REPTDATE);
  SET DEPOSIT.REPTDATE;
  SELECT;
     WHEN(1 <= DAY(REPTDATE) <= 8) CALL SYMPUT('NOWK', PUT('1', $1.));
     WHEN(9 <= DAY(REPTDATE) <= 15) CALL SYMPUT('NOWK', PUT('2', $1.));
     WHEN(16 <= DAY(REPTDATE) <= 22) CALL SYMPUT('NOWK', PUT('3', $1.));
     OTHERWISE CALL SYMPUT('NOWK', PUT('4', $1.));
  END;
  CALL SYMPUT('REPTYEAR', PUT(REPTDATE, YEAR2.));
  CALL SYMPUT('REPTMON', PUT(MONTH(REPTDATE), Z2.));
  CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));
  CALL SYMPUT('RDATE', PUT(REPTDATE, DDMMYY8.));
RUN;
*;
%LET FDVAR=(KEEP=ACCTNO BRANCH PRODUCT NAME OPENDT CLOSEDT CUSTCODE
                 INTYTD PURPOSE LEDGBAL OPENIND INTPD INTPLAN CURBAL
                 STATE CURCODE BDATE MTDAVBAL FORATE FORBAL CURBALUS
                 SECOND USER3 DNBFISME MTDAVBAL_MIS MTDAVFORBAL_MIS
                 ACSTATUS4-ACSTATUS10 POST_IND REASON INSTRUCTIONS
                 DTLSTCUST CLASSIFI REOPENDT ESIGNATURE STMT_CYCLE
                 NXT_STMT_CYCLE_DT);
*;
PROC SORT DATA=DEPOSIT.FD (RENAME=(PURPOSE=CLASSIFI))
   OUT=DEPOFD; BY ACCTNO;
*;
DATA FD;
  FORMAT PURPOSE PURPOSEM 2.;
  DROP INTPD;
  SET DEPOFD;
  PURPOSE  =SECTOR;
  PURPOSEM =SECTOR;
  INTYTD=INTPD;
  IF PRODUCT IN &FCY;
*;
PROC SORT DATA=MNIFD.FD OUT=FDCD; BY ACCTNO; RUN;
PROC SUMMARY DATA=FDCD NWAY;
BY ACCTNO; VAR INTPAY;
OUTPUT OUT=FDCD  (DROP=_TYPE_ _FREQ_) SUM=INTPD;
*;
PROC SORT DATA=SIGNA.SMSACC OUT=SAACC; BY ACCTNO; RUN;

DATA FCYFD;
   MERGE FD(IN=A) FDCD SAACC MISMTD.FAVG&REPTMON;
   BY ACCTNO;
   IF A;
   RENAME PSREASON = REASON;
   ACSTATUS4  = SUBSTR(STATCD,4,1);
   ACSTATUS5  = SUBSTR(STATCD,5,1);
   ACSTATUS6  = SUBSTR(STATCD,6,1);
   ACSTATUS7  = SUBSTR(STATCD,7,1);
   ACSTATUS8  = SUBSTR(STATCD,8,1);
   ACSTATUS9  = SUBSTR(STATCD,9,1);
   ACSTATUS10 = SUBSTR(STATCD,10,1);

   IF OPENDT NOT IN (0,.) THEN
      ODATES = INPUT(SUBSTR(PUT(OPENDT,Z11.),1,8),MMDDYY8.);
   ELSE ODATES = 0;
   OPENDT = ODATES;

   IF REOPENDT NOT IN (0,.) THEN
      RODATES = INPUT(SUBSTR(PUT(REOPENDT,Z11.),1,8),MMDDYY8.);
   REOPENDT = RODATES;

   IF CLOSEDT NOT IN (0,.) THEN
      CDATES = INPUT(SUBSTR(PUT(CLOSEDT,Z11.),1,8),MMDDYY8.);
   ELSE CDATES = CLOSEDT;
   CLOSEDT = CDATES;

   IF DTLSTCUST NOT IN (0,.) THEN
      LSTCUST = INPUT(SUBSTR(PUT(DTLSTCUST,Z9.),1,6),MMDDYY6.);
      DTLSTCUST = LSTCUST;

   IF ESIGNATURE = '' THEN ESIGNATURE = 'N';
*;
DATA DEPO.FCYFD&REPTMON&NOWK&REPTYEAR
     TEMP.FCYFD&REPTMON&NOWK&REPTYEAR;
     SET FCYFD &FDVAR;
RUN;
*;
FILENAME TRANFILE 'SAP.PBB.FCYFD.FCYFDFTP' DISP=OLD;
PROC CPORT LIBRARY=TEMP FILE=TRANFILE;
RUN;
*;
PROC PRINT DATA=DEPO.FCYFD&REPTMON&NOWK&REPTYEAR; RUN;
PROC PRINT DATA=REPTDATE;
FORMAT REPTDATE MMWYY; RUN;
