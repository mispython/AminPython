DATA REMLN;
   INFILE LNFL FIRSTOBS=5;
   INPUT @001 BRCH       4.
         @006 ISSUDT   $10.
         @017 CUSTNAME $40.
         @058 ACCTNO   $11.
         @070 BNKCHQ   $16.
         @087 CNT        8.
         @096 AMN      $14.
         @111 PURPOSE  $70.
         ;
   FORMAT AMT 12.2;
   AMT  = COMPRESS(AMN,',');
   PURP = PUT(PURPOSE, $PURPNO.);
   IF PURP IN (0,13) THEN DELETE;
RUN;
PROC PRINT; RUN;

DATA REMHP;
   INFILE HPFL FIRSTOBS=5;
   INPUT @001 BRCH       4.
