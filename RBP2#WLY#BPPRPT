import pandas as pd
import numpy as np
from datetime import datetime

# =========================
# CONFIG (CHANGE PER JOB)
# =========================
CONFIG = {
    "bank_name": "PUBLIC ISLAMIC BANK",
    "exclude_purpose": [0, 14],   # <-- KEY DIFFERENCE
    "lnfl_path": "lnfl.txt",
    "hpfl_path": "hpfl.txt",
    "brfl_path": "branch.txt",
    "output_path": "output.txt"
}

# =========================
# PURPOSE MAP (SHARED)
# =========================
PURPOSE_MAP = {
    'FEE EXPENSE/INSURANCE PREMIUM (BORNE BY CUSTOMERS)': 1,
    'DEVELOPER SALE (REDEMPTION)': 2,
    'DEVELOPER SALE/CONSTRUCTION LOAN (PROGRESSIVE RELEASE)': 3,
    'DEVELOPER SALE (FULL RELEASE)': 4,
    'SUBSALE/AUCTION PURCHASED (REDEMPTION)': 5,
    'SUBSALE (BALANCE OF LOAN RELEASE)': 6,
    'SUBSALE (FULL RELEASE)': 7,
    'REFINANCING (REDEMPTION)': 8,
    'REFINANCING (BALANCE OF LOAN RELEASE)': 9,
    'ADDITIONAL LOAN (SECURED BY THE EXISTING PROPERTY)/REINSTATEMENT': 10,
    'NEW LOAN (PROPERTY FREE FROM ENCUMBRANCES)': 11,
    'OTHERS - LEGAL FEES': 12,
    'OTHERS - TAKAFUL CONTRIBUTION (APPLICABLE TO PIBB)': 13,
    'OTHERS - LIFE INSURANCE PREMIUM (APPLICABLE TO PBB)': 14,
    'FEE EXPENSES/INSURANCE PREMIUM (BORNE BY CUSTOMERS)': 15,
    'DISBURSEMENT': 16
}

# =========================
# READ FIXED WIDTH
# =========================
def read_remittance(path, purpose_len):
    colspecs = [
        (0, 4),(5, 15),(16, 56),(57, 68),
        (69, 85),(86, 94),(95, 109),(110, 110 + purpose_len)
    ]

    df = pd.read_fwf(path, colspecs=colspecs, skiprows=4, dtype=str)
    df.columns = ["BRCH","ISSUDT","CUSTNAME","ACCTNO","BNKCHQ","CNT","AMN","PURPOSE"]

    df["CNT"] = pd.to_numeric(df["CNT"], errors="coerce").fillna(0)
    df["AMT"] = df["AMN"].str.replace(",", "", regex=False).astype(float)

    df["PURP"] = df["PURPOSE"].str.strip().map(PURPOSE_MAP).fillna(0)

    df = df[~df["PURP"].isin(CONFIG["exclude_purpose"])]

    return df

# =========================
# PROCESS
# =========================
ln_df = read_remittance(CONFIG["lnfl_path"], 70)
hp_df = read_remittance(CONFIG["hpfl_path"], 60)

df = pd.concat([ln_df, hp_df])

# category pivot
for i in range(1,17):
    df[f"CNT{i}"] = np.where(df["PURP"]==i, df["CNT"], 0)
    df[f"AMT{i}"] = np.where(df["PURP"]==i, df["AMT"], 0)

# aggregation
agg = df.groupby("BRCH").sum(numeric_only=True).reset_index()

agg["SUMCNT"] = df.groupby("BRCH")["CNT"].sum().values
agg["SUMAMT"] = df.groupby("BRCH")["AMT"].sum().values

# percentages
for i in range(1,17):
    agg[f"PCNT{i}"] = (agg[f"CNT{i}"] / agg["SUMCNT"]) * 100
    agg[f"PAMT{i}"] = (agg[f"AMT{i}"] / agg["SUMAMT"]) * 100

agg = agg.replace([np.inf, -np.inf], 0).fillna(0)

# =========================
# OUTPUT
# =========================
with open(CONFIG["output_path"], "w") as f:
    f.write(CONFIG["bank_name"] + "\n")
    f.write("SUMMARY REPORT\n\n")

    for _, row in agg.iterrows():
        f.write(f"{int(row['BRCH']):03} TOTAL CNT={row['SUMCNT']:.0f} AMT={row['SUMAMT']:.2f}\n")



				
