import pandas as pd
import numpy as np

CATEGORY_COUNT = 22

# =========================
# PURPOSE MAP (COMBINED)
# =========================
PURPOSE_MAP = {
    'HOSPITALS AND CLINICS': 1,
    'UTILITIES': 2,
    'VENDOR AND SUPPLIERS': 3,
    'TRADE FINANCE': 4,
    'GOVERNMENT AGENCIES': 5,
    'FEE EXPENSES/INSURANCE PREMIUM (BORNE BY CUSTOMERS)': 6,
    'DISBURSEMENT': 7,
    'FEE EXPENSE/INSURANCE PREMIUM (BORNE BY CUSTOMERS)': 8,
    'DEVELOPER SALE (REDEMPTION)': 9,
    'DEVELOPER SALE/CONSTRUCTION LOAN (PROGRESSIVE RELEASE)': 10,
    'DEVELOPER SALE (FULL RELEASE)': 11,
    'SUBSALE/AUCTION PURCHASED (REDEMPTION)': 12,
    'SUBSALE (BALANCE OF LOAN RELEASE)': 13,
    'SUBSALE (FULL RELEASE)': 14,
    'REFINANCING (REDEMPTION)': 15,
    'REFINANCING (BALANCE OF LOAN RELEASE)': 16,
    'ADDITIONAL LOAN (SECURED BY THE EXISTING PROPERTY)/REINSTATEMENT': 17,
    'NEW LOAN (PROPERTY FREE FROM ENCUMBRANCES)': 18,
    'OTHERS - LEGAL FEES': 19,
    'OTHERS - TAKAFUL CONTRIBUTION (APPLICABLE TO PIBB)': 20,
    'OTHERS - LIFE INSURANCE PREMIUM (APPLICABLE TO PBB)': 21,
    'OTHERS': 22
}

# =========================
# LN READER WITH RULES
# =========================
def read_ln(path, exclude):
    rows = []
    with open(path) as f:
        lines = f.readlines()[4:]

    for line in lines:
        ch = line[102:114].strip()

        if ch == "DISBURSEMENT":
            purpose = line[117:187]
        else:
            purpose = line[102:172]

        purp = PURPOSE_MAP.get(purpose.strip(), 0)

        if purp in exclude:
            continue

        rows.append({
            "BRCH": line[0:4],
            "AMT": float(line[86:99].replace(",", "")),
            "PURP": purp,
            "TYP": "LN",
            "CNT": 1
        })

    return pd.DataFrame(rows)

# =========================
# STANDARD READER
# =========================
def read_standard(path, typ):
    df = pd.read_fwf(
        path,
        colspecs=[(0,4),(86,99),(102,172)],
        skiprows=4,
        dtype=str
    )

    df.columns = ["BRCH","AMN","PURPOSE"]
    df["CNT"] = 1
    df["AMT"] = df["AMN"].str.replace(",", "", regex=False).astype(float)
    df["PURP"] = df["PURPOSE"].str.strip().map(PURPOSE_MAP).fillna(0)
    df["TYP"] = typ

    # OTHER rule
    df.loc[df["PURPOSE"].str.startswith("OTHER -"), "PURP"] = 22

    return df[df["PURP"] != 0]

# =========================
# LOAD DATA
# =========================
# HP (combined)
hp_pbb = read_standard("pbb_mchp.txt", "HP")
hp_pibb = read_standard("pibb_mchp.txt", "HP")
df_hp = pd.concat([hp_pbb, hp_pibb])

# LN (separate rules)
ln_pbb = read_ln("pbb_mcln.txt", exclude=[0,20])
ln_pibb = read_ln("pibb_mcln.txt", exclude=[0,21])
df_ln = pd.concat([ln_pbb, ln_pibb])

# OT + TF (PBB only)
df_ot = read_standard("mcot.txt", "OT")
df_tf = read_standard("mctf.txt", "TF")

df = pd.concat([df_hp, df_ln, df_ot, df_tf], ignore_index=True)

# =========================
# PIVOT
# =========================
for i in range(1, CATEGORY_COUNT + 1):
    df[f"CNT{i}"] = np.where(df["PURP"] == i, df["CNT"], 0)
    df[f"AMT{i}"] = np.where(df["PURP"] == i, df["AMT"], 0)

# =========================
# AGGREGATION
# =========================
agg = df.groupby("BRCH").sum(numeric_only=True).reset_index()

totals = df.groupby("BRCH").agg(
    SUMCNT=("CNT","sum"),
    SUMAMT=("AMT","sum")
).reset_index()

ln_tot = df[df["TYP"]=="LN"].groupby("BRCH").agg(
    LNCNT=("CNT","sum"),
    LNAMT=("AMT","sum")
).reset_index()

hp_tot = df[df["TYP"]=="HP"].groupby("BRCH").agg(
    HPCNT=("CNT","sum"),
    HPAMT=("AMT","sum")
).reset_index()

agg = agg.merge(totals, on="BRCH") \
         .merge(ln_tot, on="BRCH", how="left") \
         .merge(hp_tot, on="BRCH", how="left") \
         .fillna(0)

# =========================
# PERCENTAGE
# =========================
for i in range(1, CATEGORY_COUNT + 1):
    agg[f"PCNT{i}"] = (agg[f"CNT{i}"] / agg["SUMCNT"]) * 100
    agg[f"PAMT{i}"] = (agg[f"AMT{i}"] / agg["SUMAMT"]) * 100

agg = agg.replace([np.inf, -np.inf], 0).fillna(0)
			
