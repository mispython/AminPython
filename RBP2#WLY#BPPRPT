   ELSE DO;
     INPUT @001 BRCH       4.
           @006 ISSUDT   $10.
           @017 CUSTNAME $40.
           @058 ACCTNO   $11.
           @070 BNKCHQ   $16.
           @087 AMN      $13.
           @103 PURPOSE  $70.
           ;
   END;
   DROP CH;
   TYP  = 'LN';
   CNT  = 1;
   AMT  = COMPRESS(AMN,',')*1;
   PURP = PUT(PURPOSE, $PURPNO.);
   IF PURP IN (0) THEN DELETE;
RUN;

DATA REMLN;
   SET REMLN1 REMLN2;
RUN;

DATA REMAL;
   SET REMLN REMHP;
   ARRAY CN{15} CNT1-CNT15;
   ARRAY AM{15} AMT1-AMT15;
   DO I=1 TO 15;
      IF PURP = I THEN DO;
         CN{I} = CNT;
         AM{I} = AMT;
      END;
   END;
RUN;
