PURPOSE_MAP = {
    'HOSPITALS AND CLINICS': 1,
    'UTILITIES': 2,
    'VENDOR AND SUPPLIERS': 3,
    'TRADE FINANCE': 4,
    'GOVERNMENT AGENCIES': 5,
