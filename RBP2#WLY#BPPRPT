DATA BRH;
   INFILE BRFL;
   INPUT @002  BRCH      3.
         @006  BRCODE   $3.
         @012  BRNAME  $30.
         @050  BRSTAT   $1.
         ;
   IF BRSTAT IN ('C') THEN DELETE;
RUN;
