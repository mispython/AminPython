OPTIONS SORTDEV=3390 YEARCUTOFF=1950;

PROC FORMAT;
   VALUE $PURPNO
   'FEE EXPENSES/INSURANCE PREMIUM (BORNE BY CUSTOMERS)'              = 1
   'DISBURSEMENT'                                                     = 2
   'FEE EXPENSE/INSURANCE PREMIUM (BORNE BY CUSTOMERS)'               = 3
   'DEVELOPER SALE (REDEMPTION)'                                      = 4
   'DEVELOPER SALE/CONSTRUCTION LOAN (PROGRESSIVE RELEASE)'           = 5
   'DEVELOPER SALE (FULL RELEASE)'                                    = 6
   'SUBSALE/AUCTION PURCHASED (REDEMPTION)'                           = 7
   'SUBSALE (BALANCE OF LOAN RELEASE)'                                = 8
   'SUBSALE (FULL RELEASE)'                                           = 9
   'REFINANCING (REDEMPTION)'                                         = 10
   'REFINANCING (BALANCE OF LOAN RELEASE)'                            = 11
   'ADDITIONAL LOAN (SECURED BY THE EXISTING PROPERTY)/REINSTATEMENT' = 12
   'NEW LOAN (PROPERTY FREE FROM ENCUMBRANCES)'                       = 13
   'OTHERS - LEGAL FEES'                                              = 14
   'OTHERS - TAKAFUL CONTRIBUTION (APPLICABLE TO PIBB)'               = 15
   OTHER                                                              = 0;
RUN;

DATA REPTDATE;
   SET LOAN.REPTDATE;
   SELECT(DAY(REPTDATE));
      WHEN(8) DO; NOWK='1'; SDAY=1; END;
      WHEN(15) DO; NOWK='2'; SDAY=9; END;
      WHEN(22) DO; NOWK='3'; SDAY=16; END;
      OTHERWISE DO; NOWK='4'; SDAY=23; END;
   END;
   CALL SYMPUT('NOWK',PUT(NOWK,$2.));
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
   CALL SYMPUT('RDATE',PUT(TODAY(),DDMMYY10.));
RUN;

DATA _NULL_;
