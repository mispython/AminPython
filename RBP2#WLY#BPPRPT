    'OTHERS - LIFE INSURANCE PREMIUM (APPLICABLE TO PBB)': 20,
    'OTHERS': 21
}

# =========================
# READ STANDARD FILE
# =========================
def read_standard(path, typ):
    colspecs = [
        (0,4),(5,15),(16,56),(57,68),
        (69,85),(86,99),(102,172)
    ]

    df = pd.read_fwf(path, colspecs=colspecs, skiprows=4, dtype=str)
    df.columns = ["BRCH","ISSUDT","CUSTNAME","ACCTNO","BNKCHQ","AMN","PURPOSE"]

    df["TYP"] = typ
    df["CNT"] = 1
    df["AMT"] = df["AMN"].str.replace(",", "", regex=False).astype(float)

    df["PURP"] = df["PURPOSE"].str.strip().map(PURPOSE_MAP).fillna(0)

    # Special rule
    df.loc[df["PURPOSE"].str.startswith("OTHER -"), "PURP"] = 21

    df = df[df["PURP"] != 0]

    return df

# =========================
# READ LN WITH CONDITIONAL PARSING
# =========================
def read_ln(path):
    rows = []

    with open(path) as f:
        lines = f.readlines()[4:]

    for line in lines:
        ch = line[102:114].strip()

        if ch == "DISBURSEMENT":
            purpose = line[117:187]
        else:
            purpose = line[102:172]

        row = {
            "BRCH": line[0:4],
            "AMT": float(line[86:99].replace(",", "")),
            "PURPOSE": purpose.strip(),
            "TYP": "LN",
            "CNT": 1
        }

        rows.append(row)

    df = pd.DataFrame(rows)

    df["PURP"] = df["PURPOSE"].map(PURPOSE_MAP).fillna(0)
    df = df[df["PURP"] != 0]

    return df

# =========================
# LOAD DATA
# =========================
df_hp = read_standard(CONFIG["paths"]["HP"], "HP")
df_ln = read_ln(CONFIG["paths"]["LN"])
df_ot = read_standard(CONFIG["paths"]["OT"], "OT")
df_tf = read_standard(CONFIG["paths"]["TF"], "TF")

df = pd.concat([df_hp, df_ln, df_ot, df_tf], ignore_index=True)

# =========================
# PIVOT
# =========================
for i in range(1, CONFIG["category_count"] + 1):
    df[f"CNT{i}"] = np.where(df["PURP"] == i, df["CNT"], 0)
    df[f"AMT{i}"] = np.where(df["PURP"] == i, df["AMT"], 0)

# =========================
# AGGREGATION
# =========================
agg = df.groupby("BRCH").sum(numeric_only=True).reset_index()

# totals
totals = df.groupby("BRCH").agg(
    SUMCNT=("CNT","sum"),
    SUMAMT=("AMT","sum")
).reset_index()

ln_tot = df[df["TYP"]=="LN"].groupby("BRCH").agg(
    LNCNT=("CNT","sum"),
    LNAMT=("AMT","sum")
).reset_index()

hp_tot = df[df["TYP"]=="HP"].groupby("BRCH").agg(
    HPCNT=("CNT","sum"),
    HPAMT=("AMT","sum")
).reset_index()

agg = agg.merge(totals, on="BRCH") \
         .merge(ln_tot, on="BRCH", how="left") \
         .merge(hp_tot, on="BRCH", how="left") \
         .fillna(0)

# =========================
# PERCENTAGES
# =========================
for i in range(1, CONFIG["category_count"] + 1):
    agg[f"PCNT{i}"] = (agg[f"CNT{i}"] / agg["SUMCNT"]) * 100
    agg[f"PAMT{i}"] = (agg[f"AMT{i}"] / agg["SUMAMT"]) * 100

agg["PHPCNT"] = (agg["HPCNT"] / agg["SUMCNT"]) * 100
agg["PLNCNT"] = (agg["LNCNT"] / agg["SUMCNT"]) * 100

agg = agg.replace([np.inf, -np.inf], 0).fillna(0)

			
