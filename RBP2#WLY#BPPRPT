PROC FORMAT;
   VALUE $PURPNO
   'FEE EXPENSES/INSURANCE PREMIUM (BORNE BY CUSTOMERS)'              = 1
   'DISBURSEMENT'                                                     = 2
   'FEE EXPENSE/INSURANCE PREMIUM (BORNE BY CUSTOMERS)'               = 3
   'DEVELOPER SALE (REDEMPTION)'                                      = 4
   'DEVELOPER SALE/CONSTRUCTION LOAN (PROGRESSIVE RELEASE)'           = 5
   'DEVELOPER SALE (FULL RELEASE)'                                    = 6
   'SUBSALE/AUCTION PURCHASED (REDEMPTION)'                           = 7
   'SUBSALE (BALANCE OF LOAN RELEASE)'                                = 8
