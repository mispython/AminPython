    'SUBSALE (FULL RELEASE)': 7,
    'REFINANCING (REDEMPTION)': 8,
    'REFINANCING (BALANCE OF LOAN RELEASE)': 9,
    'ADDITIONAL LOAN (SECURED BY THE EXISTING PROPERTY)/REINSTATEMENT': 10,
    'NEW LOAN (PROPERTY FREE FROM ENCUMBRANCES)': 11,
    'OTHERS - LEGAL FEES': 12,
    'OTHERS - TAKAFUL CONTRIBUTION (APPLICABLE TO PIBB)': 13,
    'OTHERS - LIFE INSURANCE PREMIUM (APPLICABLE TO PBB)': 14,
    'FEE EXPENSES/INSURANCE PREMIUM (BORNE BY CUSTOMERS)': 15,
    'DISBURSEMENT': 16
}

# =========================
# READ FIXED WIDTH FILE
# =========================
def read_remittance_file(path, purpose_len):
    colspecs = [
        (0, 4),    # BRCH
        (5, 15),   # ISSUDT
        (16, 56),  # CUSTNAME
        (57, 68),  # ACCTNO
        (69, 85),  # BNKCHQ
        (86, 94),  # CNT
        (95, 109), # AMN
        (110, 110 + purpose_len) # PURPOSE
    ]

    df = pd.read_fwf(
        path,
        colspecs=colspecs,
        skiprows=4,
        dtype=str
    )

    df.columns = [
        "BRCH","ISSUDT","CUSTNAME","ACCTNO",
        "BNKCHQ","CNT","AMN","PURPOSE"
    ]

    # Clean numeric fields
    df["CNT"] = pd.to_numeric(df["CNT"], errors="coerce").fillna(0)
    df["AMT"] = (
        df["AMN"]
        .str.replace(",", "", regex=False)
        .astype(float)
    )

    # Map purpose
    df["PURP"] = df["PURPOSE"].str.strip().map(PURPOSE_MAP).fillna(0)

    # Filter
    df = df[~df["PURP"].isin([0, 13])]

    return df

# =========================
# READ FILES
# =========================
ln_df = read_remittance_file(LNFL_PATH, 70)
hp_df = read_remittance_file(HPFL_PATH, 60)

remal = pd.concat([ln_df, hp_df], ignore_index=True)

# =========================
# CREATE CATEGORY COLUMNS
# =========================
for i in range(1, 17):
    remal[f"CNT{i}"] = np.where(remal["PURP"] == i, remal["CNT"], 0)
    remal[f"AMT{i}"] = np.where(remal["PURP"] == i, remal["AMT"], 0)

# =========================
# AGGREGATION
# =========================
group_cols = ["BRCH"]

agg_cols = {f"CNT{i}":"sum" for i in range(1,17)}
agg_cols.update({f"AMT{i}":"sum" for i in range(1,17)})

sublh = remal.groupby(group_cols).agg(agg_cols).reset_index()

sumlh = remal.groupby("BRCH").agg(
    SUMCNT=("CNT","sum"),
    SUMAMT=("AMT","sum")
).reset_index()

sumln = remal[~remal["PURP"].isin([15,16])].groupby("BRCH").agg(
    LNCNT=("CNT","sum"),
    LNAMT=("AMT","sum")
).reset_index()

sumhp = remal[remal["PURP"].isin([15,16])].groupby("BRCH").agg(
    HPCNT=("CNT","sum"),
    HPAMT=("AMT","sum")
).reset_index()

# =========================
# READ BRANCH
# =========================
br_cols = [(1,4),(5,8),(11,41),(49,50)]

br_df = pd.read_fwf(
    BRFL_PATH,
    colspecs=br_cols,
    names=["BRCH","BRCODE","BRNAME","BRSTAT"],
    dtype=str
)

br_df = br_df[br_df["BRSTAT"] != "C"]

# =========================
# MERGE
# =========================
df = br_df.merge(sublh, on="BRCH", how="left") \
          .merge(sumln, on="BRCH", how="left") \
          .merge(sumhp, on="BRCH", how="left") \
          .merge(sumlh, on="BRCH", how="left")

df = df.fillna(0)

# =========================
# PERCENTAGES
# =========================
for i in range(1,17):
    df[f"PCNT{i}"] = (df[f"CNT{i}"] / df["SUMCNT"]) * 100
    df[f"PAMT{i}"] = (df[f"AMT{i}"] / df["SUMAMT"]) * 100

df["PHPCNT"] = (df["HPCNT"] / df["SUMCNT"]) * 100
df["PHPAMT"] = (df["HPAMT"] / df["SUMAMT"]) * 100
df["PLNCNT"] = (df["LNCNT"] / df["SUMCNT"]) * 100
df["PLNAMT"] = (df["LNAMT"] / df["SUMAMT"]) * 100

df = df.replace([np.inf, -np.inf], 0).fillna(0)

# =========================
# OUTPUT (SIMPLIFIED TEXT)
# =========================
with open(OUTPUT_PATH, "w") as f:
    f.write("PUBLIC BANK REPORT\n")
    f.write(f"DATE: {datetime.today().strftime('%d/%m/%Y')}\n\n")

    for i, row in df.iterrows():
        f.write(f"{int(row['BRCH']):03} {row['BRNAME'].strip()}\n")
        f.write(f"TOTAL CNT: {row['SUMCNT']:.0f}  TOTAL AMT: {row['SUMAMT']:.2f}\n")
        f.write("\n")


