   PURP = PUT(PURPOSE, $PURPNO.);
   IF PURP IN (0) THEN DELETE;
RUN;

DATA REMHP2;
   INFILE MCHP FIRSTOBS=5;
   INPUT @001 BRCH       4.
         @006 ISSUDT   $10.
         @017 CUSTNAME $40.
         @058 ACCTNO   $11.
         @070 BNKCHQ   $16.
         @087 AMN      $13.
