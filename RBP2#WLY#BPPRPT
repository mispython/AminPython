DATA REMLN1;
   INFILE LNFL FIRSTOBS=5;
   INPUT @001 BRCH       4.
         @006 ISSUDT   $10.
         @017 CUSTNAME $40.
         @058 ACCTNO   $11.
         @070 BNKCHQ   $16.
         @087 CNT        8.
         @096 AMN      $14.
         @111 PURPOSE  $70.
         ;
   TYP  = 'LN';
   AMT  = COMPRESS(AMN,',')*1;
   PURP = PUT(PURPOSE, $PURPNO.);
   IF PURP IN (0) THEN DELETE;
RUN;

DATA REMLN2;
   INFILE MCLN FIRSTOBS=5;
   INPUT @103 CH       $12. @;
   IF CH = 'DISBURSEMENT' THEN DO;
     INPUT @001 BRCH       4.
           @006 ISSUDT   $10.
           @017 CUSTNAME $40.
           @058 ACCTNO   $11.
           @070 BNKCHQ   $16.
           @087 AMN      $13.
           @118 PURPOSE  $70.
           ;
