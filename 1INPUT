PROC SQL;
	CREATE TABLE DST_IBB_IBL01 AS 
   	SELECT t1.ENTITY_CD, 
           t1.ACK, 
           t1.NATURAL_ACCT, 
           t1.WALKER_PROD, 
           t1.CURRENCY_CD, 
           t1.SOURCE_CURRENCY_CD, 
           t1.REC_TYPE, 
           t1.YEAR, 
           t1.VERSION, 
           t1.EFFECTIVE_DT FORMAT=DDMMYY10. AS EFFECTIVE_DT, 
           t1.JE_GROUP_NUM, 
           t1.JE_GROUP_DT, 
           t1.JE_NUM, 
           t1.JE_SEQ_NUM, 
           t1.JE_DT, 
           t1.JE_ENTRY_TIME, 
           t1.JE_AMT, 
           t1.ORIG_JE_AMT, 
           t1.JE_ENTRY_DT, 
           t1.POSTING_DT, 
           t1.POSTING_TIME, 
           t1.JE_DESC, 
           t1.JE_DOC_REF, 
           t1.JE_TRAN_TYPE_CD, 
           t1.TERMINAL_ID, 
           t1.USERID, 
           t1.SOURCE_ACK, 
           t1.AUTO_ENTRY_FLG, 
           t1.PERIOD, 
           t1.SUMMARY_ACK_FLG, 
           t1.ENCUMB_ID, 
           t1.CONVERSION_RT_IND, 
           t1.EXCHANGE_RT, 
           t1.BASE_CURRENCY_FLG, 
           t1.EXCHANGE_RT_TYPE, 
           t1.EXCHANGE_RT_EFFECTIVE_DT, 
           t1.SERIAL_NUM, 
           t1.TFR_PRICE_EFFECTIVE_DT, 
           t1.RECON_FLG, 
           t1.SOURCE_SYSTEM_CD, 
           t1.SOURCE_SYSTEM_SEQ, 
           t1.GEN_DATE, 
           t2.TYPE, 
           /* VALID_IND */
           (CASE WHEN t1.CURRENCY_CD <> "MYR" AND t1.SOURCE_CURRENCY_CD = "" THEN 1
                 WHEN t1.CURRENCY_CD = "MYR" AND t1.SOURCE_CURRENCY_CD = "" AND SUBSTR(t1.JE_DESC,1,21) = "PBB_LND_ACCRINT_REVAL" THEN 1
                 WHEN t1.CURRENCY_CD = "MYR" AND t1.SOURCE_CURRENCY_CD = "" AND SUBSTR(t1.JE_DESC,1,22) = "PIBB_LND_ACCRINT_REVAL" THEN 1
                 ELSE 0 
            END) AS VALID_IND
      	FROM G39 t1
		INNER JOIN EGS_FD.KEEP_IBB_IBL_FCY_NATURAL_ACCT t2 ON (t1.NATURAL_ACCT = t2.NATURAL_ACCT);
QUIT;

