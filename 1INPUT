PROC SQL;
   CREATE TABLE DST_IBL04 AS 
   SELECT t1.DEALREF, 
          /* DATE */
            (put(month(t1.EFFECTIVE_DT)*100+day(t1.EFFECTIVE_DT),z4.)) AS DATE, 
