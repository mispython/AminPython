#!/usr/bin/env python3
from __future__ import annotations

import argparse
from dataclasses import dataclass
from pathlib import Path

import pandas as pd
import pyreadstat
import saspy


SAS_EPOCH = pd.Timestamp("1960-01-01")


@dataclass
class VarSpec:
    name: str
    typ: str      # "char" or "num"
    length: int


DATE_CHAR_COLS = {
    "WRIOFF_DT",
    "REPOSDTE",
    "VALUEDTE",
    "MAN_REV_DATE",
    "SYS_REV_DATE",
    "LMO_MAINT_DT",
}


LOAN_PLOAN_SCHEMA = [
    VarSpec("LOANTYPE", "num", 4),
    VarSpec("NTBRCH", "num", 4),
    VarSpec("NOTETERM", "num", 4),
    VarSpec("ISSDTE", "num", 4),
    VarSpec("BLDATE", "num", 4),
    VarSpec("DAYS", "num", 4),
    VarSpec("LOANSTAT", "num", 3),
    VarSpec("ACCTNO", "num", 8),
    VarSpec("NOTENO", "num", 8),
    VarSpec("SPP1", "num", 8),
    VarSpec("SPP2", "num", 8),
    VarSpec("NETBALP", "num", 8),
    VarSpec("CURBALP", "num", 8),
    VarSpec("NAME", "char", 24),
    VarSpec("IISP", "num", 8),
    VarSpec("UHCP", "num", 8),
    VarSpec("OIP", "num", 8),
    VarSpec("EXIST", "char", 1),
    VarSpec("PENDBRH", "num", 8),
    VarSpec("CURBAL", "num", 8),
    VarSpec("APPVALUE", "num", 8),
    VarSpec("COSTCTR", "num", 8),
    VarSpec("ORGBAL", "num", 8),
    VarSpec("NETPROC", "num", 8),
    VarSpec("INTRATE", "num", 8),
    VarSpec("ACCRUAL", "num", 8),
    VarSpec("BORSTAT", "char", 1),
    VarSpec("MARKETVL", "num", 8),
    VarSpec("EARNTERM", "num", 8),
    VarSpec("FEETOT2", "num", 8),
    VarSpec("FEEAMT3", "num", 8),
    VarSpec("BILPAY", "num", 8),
    VarSpec("FEEAMT4", "num", 8),
    VarSpec("VINNO", "char", 20),
    VarSpec("FEEYTD", "num", 8),
    VarSpec("FEEPDYTD", "num", 8),
    VarSpec("FEEAMT8", "num", 8),
    VarSpec("USER5", "char", 1),
    VarSpec("FEEAMTA", "num", 8),
    VarSpec("FEEAMT", "num", 8),
    VarSpec("FEEAMT5", "num", 8),
    VarSpec("OLDNOTEDAYARR", "num", 8),
    VarSpec("CENSUS7", "char", 8),
    VarSpec("TERMCHG", "num", 8),
]


def schema_from_metadata(df: pd.DataFrame, meta) -> list[VarSpec]:
    schema: list[VarSpec] = []

    for col in df.columns:
        name = col.upper()
        readstat_type = meta.readstat_variable_types.get(col, "")
        width = meta.variable_storage_width.get(col, 8)

        if readstat_type == "string" or name in DATE_CHAR_COLS:
            schema.append(VarSpec(name, "char", int(width or 8)))
        else:
            schema.append(VarSpec(name, "num", int(width or 8)))

    return schema


def read_sas_with_schema(path: Path) -> tuple[pd.DataFrame, list[VarSpec]]:
    df, meta = pyreadstat.read_sas7bdat(str(path))
    schema = schema_from_metadata(df, meta)
    df.columns = [c.upper() for c in df.columns]
    return df, schema


def to_sas_date_number(series: pd.Series) -> pd.Series:
    dt = pd.to_datetime(series, errors="coerce")
    return (dt - SAS_EPOCH).dt.days


def enforce_schema(df: pd.DataFrame, schema: list[VarSpec]) -> pd.DataFrame:
    df = df.copy()
    df.columns = [c.upper() for c in df.columns]

    for spec in schema:
        if spec.name not in df.columns:
            df[spec.name] = "" if spec.typ == "char" else pd.NA

        if spec.typ == "char":
            if pd.api.types.is_datetime64_any_dtype(df[spec.name]):
                df[spec.name] = df[spec.name].dt.strftime("%Y%m%d")

            df[spec.name] = (
                df[spec.name]
                .where(df[spec.name].notna(), "")
                .astype(str)
                .replace({"nan": "", "NaT": "", "<NA>": ""})
                .str.replace(".0", "", regex=False)
                .str.slice(0, spec.length)
            )
        else:
            if spec.name in {"ISSDTE", "BLDATE"}:
                df[spec.name] = to_sas_date_number(df[spec.name])
            else:
                df[spec.name] = pd.to_numeric(df[spec.name], errors="coerce")

    return df[[spec.name for spec in schema]]


def sas_length_code(schema: list[VarSpec]) -> str:
    lines = []

    for spec in schema:
        if spec.typ == "char":
            lines.append(f"length {spec.name} ${spec.length};")
        else:
            lines.append(f"length {spec.name} {spec.length};")

    return "\n".join(lines)


def write_sas7bdat_with_schema(
    sas: saspy.SASsession,
    df: pd.DataFrame,
    table_name: str,
    schema: list[VarSpec],
    libref: str = "OUT",
) -> None:
    df = enforce_schema(df, schema).reset_index(drop=True)

    tmp_table = f"_{table_name.lower()}_tmp"
    sas.df2sd(df, table=tmp_table, libref=libref)

    code = f"""
data {libref}.{table_name.lower()};
  {sas_length_code(schema)}
  set {libref}.{tmp_table};
run;

proc datasets lib={libref} nolist;
  delete {tmp_table};
quit;
"""
    result = sas.submit(code)

    if "ERROR:" in result["LOG"]:
        print(result["LOG"])
        raise RuntimeError(f"Failed writing {table_name}.sas7bdat")


def next_bldate(row: pd.Series) -> pd.Timestamp:
    issdte = row.get("ISSDTE")
    bldate = row.get("BLDATE")

    if pd.isna(issdte) or pd.isna(bldate):
        return bldate

    issdte = pd.to_datetime(issdte)
    bldate = pd.to_datetime(bldate)

    dd = issdte.day
    mm = bldate.month + 1
    yy = bldate.year

    if mm > 12:
        mm = 1
        yy += 1

    last_day = pd.Timestamp(year=yy, month=mm, day=1) + pd.offsets.MonthEnd(0)
    dd = min(dd, last_day.day)

    return pd.Timestamp(year=yy, month=mm, day=dd)


def prepare_loan(lnnote: pd.DataFrame) -> pd.DataFrame:
    loan_types = [128, 130, 380, 381, 700, 705, 131, 132, 720, 725]

    df = lnnote[
        (lnnote["REVERSED"].fillna("") != "Y")
        & lnnote["NOTENO"].notna()
        & (lnnote["PAIDIND"].fillna("") != "P")
        & lnnote["NTBRCH"].notna()
        & lnnote["LOANTYPE"].isin(loan_types)
    ].copy()

    return df.sort_values(["ACCTNO", "NOTENO"])


def prepare_lnnote(lnnote: pd.DataFrame) -> pd.DataFrame:
    lnnote_types = [128, 130, 700, 705, 983, 993, 996, 380, 381, 131, 132, 720, 725]

    df = lnnote[
        (lnnote["REVERSED"].fillna("") != "Y")
        & lnnote["NOTENO"].notna()
        & lnnote["NTBRCH"].notna()
        & lnnote["LOANTYPE"].isin(lnnote_types)
    ].copy()

    df = df.drop(columns=["NFEEAMT10", "NFEEAMT11", "NFEEAMT12"], errors="ignore")
    df = df.sort_values(["ACCTNO", "NOTENO"], ascending=[True, False])
    df = df.drop_duplicates(subset=["ACCTNO"], keep="first")

    loanno_types = [128, 130, 380, 381, 700, 705, 983, 993, 996, 131, 132, 720, 725]

    loanno = lnnote[
        (lnnote["REVERSED"].fillna("") != "Y")
        & lnnote["NOTENO"].notna()
        & (lnnote["PAIDIND"].fillna("") != "P")
        & lnnote["NTBRCH"].notna()
        & lnnote["LOANTYPE"].isin(loanno_types)
    ][["ACCTNO", "NOTENO"]].copy()

    loanno = loanno.sort_values(["ACCTNO", "NOTENO"], ascending=[True, False])
    loanno = loanno.drop_duplicates(subset=["ACCTNO"], keep="first")

    df = df.drop(columns=["NOTENO"], errors="ignore")
    df = df.merge(loanno, on="ACCTNO", how="left")

    return df.sort_values("ACCTNO")


def sas_like_merge_left(base: pd.DataFrame, right: pd.DataFrame) -> pd.DataFrame:
    base = base.sort_values("ACCTNO").copy()
    right = right.sort_values("ACCTNO").copy()

    overlap = [c for c in right.columns if c in base.columns and c != "ACCTNO"]
    base = base.drop(columns=overlap, errors="ignore")

    return base.merge(right, on="ACCTNO", how="left")


def main() -> None:
    parser = argparse.ArgumentParser(description="EIFMNP02 pure Python conversion")
    parser.add_argument("--reptdate-value", required=True)
    parser.add_argument("--lnnote", type=Path, required=True)
    parser.add_argument("--wiis", type=Path, required=True)
    parser.add_argument("--waq", type=Path, required=True)
    parser.add_argument("--wsp2", type=Path, required=True)
    parser.add_argument("--nplobal", type=Path, required=True)
    parser.add_argument("--output-dir", type=Path, required=True)

    args = parser.parse_args()

    for path in [args.lnnote, args.wiis, args.waq, args.wsp2, args.nplobal]:
        if not path.exists():
            raise FileNotFoundError(f"Missing input file: {path}")

    args.output_dir.mkdir(parents=True, exist_ok=True)

    rept_date_value = pd.to_datetime(args.reptdate_value, format="%Y%m%d")
    reptmon = rept_date_value.strftime("%m")

    lnnote_raw, _ = read_sas_with_schema(args.lnnote)
    wiis, wiis_schema = read_sas_with_schema(args.wiis)
    waq, waq_schema = read_sas_with_schema(args.waq)
    wsp2, wsp2_schema = read_sas_with_schema(args.wsp2)
    nplobal, _ = read_sas_with_schema(args.nplobal)

    reptdate = pd.DataFrame({"REPTDATE": [rept_date_value]})

    loan = prepare_loan(lnnote_raw)
    lnnote = prepare_lnnote(lnnote_raw)

    wiis_out = sas_like_merge_left(wiis, lnnote)
    waq_out = sas_like_merge_left(waq, lnnote)
    wsp2_out = sas_like_merge_left(wsp2, lnnote)

    nplobal_keep = [
        "ACCTNO", "NOTENO", "NTBRCH", "NAME", "LOANTYPE", "LOANSTAT",
        "IISP", "OIP", "SPP1", "SPP2", "CURBALP", "NETBALP", "EXIST", "UHCP",
    ]
    nplobal_base = nplobal[[c for c in nplobal_keep if c in nplobal.columns]].copy()

    wiis_acct = wiis[["ACCTNO"]].drop_duplicates().copy()
    wiis_acct["IN_WIIS"] = True

    nplobal6_base = nplobal_base.merge(wiis_acct, on="ACCTNO", how="outer")
    nplobal6_base["IN_WIIS"] = nplobal6_base["IN_WIIS"].fillna(False)

    nplobal6 = sas_like_merge_left(nplobal6_base, lnnote)

    nplobal6.loc[nplobal6["IN_WIIS"], "BORSTAT"] = "W"
    nplobal6 = nplobal6.drop(columns=["IN_WIIS"], errors="ignore")

    loan_for_merge = loan.drop(columns=["LOANSTAT"], errors="ignore").copy()

    nplobal_keys = nplobal6[["ACCTNO"]].drop_duplicates()
    loan_keys = loan_for_merge[["ACCTNO"]].drop_duplicates()

    nplobal_for_loan = nplobal6.drop(
        columns=[c for c in nplobal6.columns if c in loan_for_merge.columns and c != "ACCTNO"],
        errors="ignore",
    )

    loan_part = loan_for_merge.merge(
        nplobal_for_loan,
        on="ACCTNO",
        how="left",
    )
    loan_part["_SOURCE"] = "LOAN"

    nplobal_only = nplobal6[
        ~nplobal6["ACCTNO"].isin(loan_keys["ACCTNO"])
    ].copy()
    nplobal_only["_SOURCE"] = "NPLOBAL_ONLY"

    merged = pd.concat([loan_part, nplobal_only], ignore_index=True, sort=False)

    merged["REPTDATE"] = rept_date_value

    if "BORSTAT" not in merged.columns:
        merged["BORSTAT"] = ""

    merged = merged[merged["BORSTAT"].fillna("") != "Z"].copy()

    if "ISSUEDT" in merged.columns:
        issue_str = (
            merged["ISSUEDT"]
            .fillna(0)
            .astype("int64")
            .astype(str)
            .str.zfill(11)
            .str[:8]
        )
        merged["ISSDTE"] = pd.to_datetime(issue_str, format="%m%d%Y", errors="coerce")

    if "CENSUS" in merged.columns:
        merged["CENSUS7"] = merged["CENSUS"].map(
            lambda x: f"{x:8.2f}"[6:7] if pd.notna(x) else ""
        )

    if "BLDATE" in merged.columns:
        merged["BLDATE"] = pd.to_datetime(merged["BLDATE"], errors="coerce")
    else:
        merged["BLDATE"] = pd.NaT

    if "ACCTNO" in merged.columns:
        merged.loc[merged["ACCTNO"] == 8095419311, "BLDATE"] = pd.Timestamp("1997-01-21")

    biltot = merged.get("BILTOT", pd.Series(index=merged.index, dtype="float64")).fillna(0)
    bilpay = merged.get("BILPAY", pd.Series(index=merged.index, dtype="float64")).fillna(0)
    safe_bilpay = bilpay.replace(0, pd.NA)

    nxt_mask = (
        merged["BLDATE"].notna()
        & (bilpay > 0)
        & ((biltot / safe_bilpay) <= 0.01)
    )
    merged.loc[nxt_mask, "BLDATE"] = merged.loc[nxt_mask].apply(next_bldate, axis=1)

    merged["DAYS"] = (rept_date_value - merged["BLDATE"]).dt.days

    old_arr = merged.get("OLDNOTEDAYARR", pd.Series(index=merged.index, dtype="float64")).fillna(0)
    noteno = merged.get("NOTENO", pd.Series(index=merged.index, dtype="float64"))

    arr_mask = (old_arr > 0) & (noteno >= 98000) & (noteno <= 98999)
    merged.loc[arr_mask & (merged["DAYS"] < 0), "DAYS"] = 0
    merged.loc[arr_mask, "DAYS"] = merged.loc[arr_mask, "DAYS"] + old_arr[arr_mask]

    intamt = merged.get("INTAMT", pd.Series(index=merged.index, dtype="float64")).fillna(0)
    intearn2 = merged.get("INTEARN2", pd.Series(index=merged.index, dtype="float64")).fillna(0)

    merged["TERMCHG"] = 0.0
    merged.loc[intamt > 0.1, "TERMCHG"] = intamt[intamt > 0.1] + intearn2[intamt > 0.1]

    if "NOTENO" not in merged.columns:
        merged["NOTENO"] = pd.NA

    stat_mask = (
        ~merged["BORSTAT"].fillna("").isin(["F", "I", "R", "Y", "W", "Z", "A"])
        & merged["NOTENO"].isin([98010, 98011, 99010, 99011])
    )
    merged.loc[stat_mask, "BORSTAT"] = "S"

    from_nplobal6 = merged["ACCTNO"].isin(nplobal_keys["ACCTNO"])
    no_loan_mask = merged["_SOURCE"].eq("NPLOBAL_ONLY")

    if "LOANSTAT" not in merged.columns:
        merged["LOANSTAT"] = pd.NA

    merged.loc[no_loan_mask, "LOANSTAT"] = pd.NA
    merged.loc[no_loan_mask, "DAYS"] = 0
    merged.loc[no_loan_mask, "BORSTAT"] = ""

    merged.loc[from_nplobal6 & (merged["DAYS"] <= 0), "LOANSTAT"] = 1
    merged.loc[
        from_nplobal6
        & (merged["LOANSTAT"] == 1)
        & (merged["BORSTAT"].fillna("") == ""),
        "BORSTAT",
    ] = "A"

    user5 = merged.get("USER5", pd.Series(index=merged.index, dtype="object")).fillna("")

    other_condition = (
        (merged["DAYS"] > 89)
        | (~merged["BORSTAT"].fillna("").isin(["", "A", "C", "S", "T"]))
        | (user5 == "N")
    )

    loan_rows = from_nplobal6 | (~from_nplobal6 & other_condition)
    ploan_rows = ~from_nplobal6 & ~other_condition

    y_to_ploan = (
        ~from_nplobal6
        & other_condition
        & (merged["BORSTAT"].fillna("") == "Y")
        & (merged["DAYS"] <= 182)
    )

    loan_rows = loan_rows & ~y_to_ploan
    ploan_rows = ploan_rows | y_to_ploan

    sas = saspy.SASsession()

    try:
        sas.saslib("OUT", path=str(args.output_dir))

        write_sas7bdat_with_schema(
            sas,
            reptdate,
            "reptdate",
            [VarSpec("REPTDATE", "num", 8)],
        )
        write_sas7bdat_with_schema(sas, wiis_out, "wiis", wiis_schema)
        write_sas7bdat_with_schema(sas, waq_out, "waq", waq_schema)
        write_sas7bdat_with_schema(sas, wsp2_out, "wsp2", wsp2_schema)
        write_sas7bdat_with_schema(
            sas,
            merged.loc[loan_rows],
            f"loan{reptmon}",
            LOAN_PLOAN_SCHEMA,
        )
        write_sas7bdat_with_schema(
            sas,
            merged.loc[ploan_rows],
            f"ploan{reptmon}",
            LOAN_PLOAN_SCHEMA,
        )
    finally:
        sas.endsas()

    print(f"REPTDATE : {args.reptdate_value}")
    print(f"Created  : {args.output_dir / 'reptdate.sas7bdat'}")
    print(f"Created  : {args.output_dir / 'wiis.sas7bdat'}")
    print(f"Created  : {args.output_dir / 'waq.sas7bdat'}")
    print(f"Created  : {args.output_dir / 'wsp2.sas7bdat'}")
    print(f"Created  : {args.output_dir / f'loan{reptmon}.sas7bdat'}")
    print(f"Created  : {args.output_dir / f'ploan{reptmon}.sas7bdat'}")


if __name__ == "__main__":
    main()
