%let oldpath=/dwh/test;
%let newpath=/dwh/compare;
%let outfile=/dwh/compare/wof03_compare_report.txt;

libname old "&oldpath";
libname new "&newpath";

filename rpt "&outfile";

proc printto print=rpt new;
run;

title "WOF03 COMPARE REPORT";

%macro ds_exists(lib, ds);
  %sysfunc(exist(&lib..&ds))
%mend;

%macro report_contents(ds);
  title2 "CONTENTS OLD.&ds";
  proc contents data=old.&ds varnum;
  run;

  title2 "CONTENTS NEW.&ds";
  proc contents data=new.&ds varnum;
  run;
%mend;

%macro report_counts(ds, key);
  title2 "COUNT CHECK &ds";

  proc sql;
    select "OLD.&ds" as dataset length=30,
           count(*) as nobs
    from old.&ds;

    select "NEW.&ds" as dataset length=30,
           count(*) as nobs
    from new.&ds;
  quit;

  title2 "DUPLICATE KEY CHECK OLD.&ds";
  proc sql;
    select &key, count(*) as cnt
    from old.&ds
    group by &key
    having calculated cnt > 1;
  quit;

  title2 "DUPLICATE KEY CHECK NEW.&ds";
  proc sql;
    select &key, count(*) as cnt
    from new.&ds
    group by &key
    having calculated cnt > 1;
  quit;
%mend;

%macro report_compare(ds, key);
  %if %ds_exists(old, &ds) and %ds_exists(new, &ds) %then %do;

    %report_contents(&ds);
    %report_counts(&ds, &key);

    proc sort data=old.&ds out=old_&ds;
      by &key;
    run;

    proc sort data=new.&ds out=new_&ds;
      by &key;
    run;

    title2 "PROC COMPARE OLD.&ds VS NEW.&ds";
    proc compare base=old_&ds compare=new_&ds
                 criterion=0.000001 method=absolute
                 listall maxprint=(50,500);
      id &key;
    run;

  %end;
  %else %do;
    title2 "MISSING DATASET &ds";
    data _null_;
      file print;
      put "Dataset &ds missing in OLD or NEW library.";
    run;
  %end;
%mend;

%report_compare(wiis, acctno);
%report_compare(waq, acctno);
%report_compare(wsp2, acctno);
%report_compare(loan07, acctno noteno);
%report_compare(ploan07, acctno noteno);

proc printto;
run;
