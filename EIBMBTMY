#!/usr/bin/env python3
"""
Python conversion of mainframe SAS job EIBMBTMY.

- BNM input = SAS7BDAT dataset
- LOAN.REPTDATE replaced with today date
- Same input/output structure as previous jobs
"""

from __future__ import annotations

import argparse
from datetime import date
from pathlib import Path

import pandas as pd


DEFAULT_BASE = Path("Data_Warehouse/MIS/XMIS/input/prod")
DEFAULT_OUTPUT_DIR = DEFAULT_BASE / "output"


def get_report_variables(reptdate: date) -> dict[str, str]:

    day = reptdate.day

    week_map = {
        8: ("1", "4", "", "", 1),
        15: ("2", "1", "", "", 9),
        22: ("3", "2", "", "", 16),
    }

    wk, wk1, wk2, wk3, sdd = week_map.get(
        day,
        ("4", "3", "2", "1", 23)
    )

    mm = reptdate.month

    mm1 = (
        12 if wk == "1" and mm == 1
        else (mm - 1 if wk == "1" else mm)
    )

    sdate = date(reptdate.year, mm, sdd)

    return {
        "NOWK": wk,
        "NOWK1": wk1,
        "NOWK2": wk2,
        "NOWK3": wk3,
        "REPTMON": f"{mm:02d}",
        "REPTMON1": f"{mm1:02d}",
        "REPTYEAR": str(reptdate.year),
        "REPTDAY": f"{day:02d}",
        "RDATE": reptdate.strftime("%d/%m/%y"),
        "SDATE": sdate.strftime("%d/%m/%y"),
    }


def resolve_input_path(path: Path) -> Path:

    if path.exists():
        return path

    sas_path = path.with_suffix(".sas7bdat")

    if sas_path.exists():
        return sas_path

    return path


def read_sas_dataset(path: Path) -> pd.DataFrame:

    return pd.read_sas(
        path,
        format="sas7bdat",
        encoding="utf-8"
    )


def main() -> None:

    parser = argparse.ArgumentParser(
        description="Convert SAS EIBMBTMY to Python"
    )

    parser.add_argument(
        "--bnm",
        type=Path,
        default=DEFAULT_BASE / "BTMAST.sas7bdat",
        help="BNM SAS7BDAT dataset",
    )

    parser.add_argument(
        "--output-dir",
        type=Path,
        default=DEFAULT_OUTPUT_DIR,
    )

    args = parser.parse_args()

    output_dir = args.output_dir
    output_dir.mkdir(parents=True, exist_ok=True)

    # ----------------------------------------------------------
    # REPORT VARIABLES
    # ----------------------------------------------------------

    reptdate = date.today()

    vars = get_report_variables(reptdate)

    # ----------------------------------------------------------
    # INPUT
    # ----------------------------------------------------------

    bnm_path = resolve_input_path(args.bnm)

    df = read_sas_dataset(bnm_path)

    df.columns = [col.upper() for col in df.columns]

    # ----------------------------------------------------------
    # FILTER APPROVE
    # ----------------------------------------------------------

    df["ACCTNO"] = df["ACCTNO"].astype(str)

    approve = df[
        (df["LEVELS"] == 1)
        & (df["D"] == 1)
        & (df["ACCTNO"].str[:2] == "25")
    ].copy()

    # ----------------------------------------------------------
    # CATEGORY
    # ----------------------------------------------------------

    approve["CATEGORY"] = ""

    approve.loc[
        approve["RETAILID"] == "C",
        "CATEGORY"
    ] = "CORPORATE"

    approve.loc[
        approve["RETAILID"] == "R",
        "CATEGORY"
    ] = "RETAIL"

    # ----------------------------------------------------------
    # SUMMARY
    # ----------------------------------------------------------

    prt = (
        approve.groupby(
            ["BRANCH", "CATEGORY"],
            dropna=False
        )
        .agg(
            ACCT=("APPRLIMT", "count"),
            APPRLIMT=("APPRLIMT", "sum"),
        )
        .reset_index()
    )

    # ----------------------------------------------------------
    # FILTER BRANCH
    # ----------------------------------------------------------

    prt = prt[prt["BRANCH"] > 0].copy()

    # ----------------------------------------------------------
    # BRANCH NAME
    # ----------------------------------------------------------

    # Replace with actual branch mapping if available
    prt["BRHNAME"] = ""

    prt["BRANCHX"] = (
        prt["BRANCH"]
        .astype(int)
        .astype(str)
        .str.zfill(3)
        + "-"
        + prt["BRHNAME"]
    )

    # ----------------------------------------------------------
    # OUTPUT CSV
    # ----------------------------------------------------------

    output_csv = output_dir / "BT_LIMIT_REPORT.csv"

    prt.to_csv(
        output_csv,
        index=False
    )

    # ----------------------------------------------------------
    # SASLIST REPORT
    # ----------------------------------------------------------

    saslist = output_dir / "SASLIST.txt"

    with saslist.open("w", encoding="utf-8") as f:

        f.write(
            "PUBLIC BANK BERHAD. REPORT-ID: EIBMBTMY\n"
        )

        f.write(
            f"MONTHLY TRADE BILLS BY APPROVE LIMIT & NO.OF ACCTS {vars['RDATE']}\n\n"
        )

        f.write(
            f"{'BRANCH':<20}"
            f"{'CATEGORY':<15}"
            f"{'ACCTS':>12}"
            f"{'LIMITS(RM)':>20}\n"
        )

        f.write("-" * 70 + "\n")

        for _, row in prt.iterrows():

            f.write(
                f"{row['BRANCHX']:<20}"
                f"{row['CATEGORY']:<15}"
                f"{int(row['ACCT']):>12,}"
                f"{row['APPRLIMT']:>20,.2f}\n"
            )

    print(f"CSV Output : {output_csv}")
    print(f"SASLIST    : {saslist}")


if __name__ == "__main__":
    main()
