DATA DPBTRAN;
  FORMAT ENTITY $30.;
  MERGE DPBTRAN(IN=A) FULL_BASE_DP(IN=B);
  BY ACCTNO;
  IF A;
  IF ENTITY = '' THEN DO;
    IF (4000000000<=ACCTNO<=4699999999) OR
	   (3000000000<=ACCTNO<=3399999999) OR
	   (3409999999<=ACCTNO<=3589999999) OR
	   (3599999999<=ACCTNO<=3789999999) OR
	   (3794999999<=ACCTNO<=3799999999) OR
	   (3399999999<=ACCTNO<=3409999999) OR
	   (3589999999<=ACCTNO<=3599999999) OR
	   (1000000000<=ACCTNO<=1799999999) OR
       (2000000000<=ACCTNO<=2499999999) OR
	   (2499999999<=ACCTNO<=2519999999) OR
	   (2789999999<=ACCTNO<=2799999999) OR
	   (6199999999<=ACCTNO<=6299999999) OR
       (6315674000<=ACCTNO<=6499999999) OR
       (6570000000<=ACCTNO<=6589999999) OR
	   (8000000000<=ACCTNO<=8799999999) THEN  ENTITY = 'PBB';
	ELSE ENTITY = 'PIBB'; 
 END;
