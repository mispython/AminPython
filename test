DATA DPBTRAN;
   SET DP.DPBTRAN&REPTYEAR&REPTMON.01(KEEP=ACCTNO TRANCODE TRANAMT ORITXNCD LTRAIL1 LTRAIL2 CHANNEL) 
       DP.DPBTRAN&REPTYEAR&REPTMON.02(KEEP=ACCTNO TRANCODE TRANAMT ORITXNCD LTRAIL1 LTRAIL2 CHANNEL)
