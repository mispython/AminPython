DATA REPTDATE;
/*	%let SAS_DT_SASDLY = '01APR26'D;*/
	%let SAS_DT_SASDLY = '01MAR26'D;
  REPTDATE = &SAS_DT_SASDLY - DAY(&SAS_DT_SASDLY);
  STARTDT  = MDY(MONTH(REPTDATE),1,YEAR(REPTDATE)); 
  CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));      
  CALL SYMPUT('REPTMON' ,PUT(MONTH(REPTDATE),Z2.));   
  CALL SYMPUT('NOWK' ,PUT(4,1.));
  CALL SYMPUT('TDATE',REPTDATE);
  CALL SYMPUT('REPTYR',PUT(REPTDATE,YEAR4.));  
  CALL SYMPUT('DAY',PUT(DAY(REPTDATE),Z2.));
  CALL SYMPUT('STARTDT',STARTDT);
RUN;
