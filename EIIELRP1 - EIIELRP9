import os
import pandas as pd

# ==========================================
# DATASET
# ==========================================
TEMP_DATASET = "data/TEMP_COLDRPT.parquet"

# OUTPUT
OUT_9A = "EIIMRP9A.COLD"
OUT_9B = "EIIMRP9B.COLD"
OUT_9C = "EIIMRP9C.COLD"
OUT_9D = "EIIMRP9D.COLD"

LRECL = 220


# ==========================================
# DELETE STEP
# ==========================================
def delete_datasets():
    for f in [OUT_9A, OUT_9B, OUT_9C, OUT_9D]:
        if os.path.exists(f):
            os.remove(f)


# ==========================================
# WRITE FB 220
# ==========================================
def write_fb_220(df, path):
    with open(path, "w") as f:
        for _, row in df.iterrows():
            line = "".join(str(v).ljust(20) for v in row)
            line = line[:LRECL].ljust(LRECL)
            f.write(line + "\n")


# ==========================================
# EIIMRP9A
# ==========================================
def EIIMRP9A():
    df = pd.read_parquet(TEMP_DATASET)
    write_fb_220(df, OUT_9A)


# ==========================================
# EIIMRP9B
# ==========================================
def EIIMRP9B():
    df = pd.read_parquet(TEMP_DATASET)
    df = df.sort_values(by=["BRANCH"])
    write_fb_220(df, OUT_9B)


# ==========================================
# EIIMRP9C
# ==========================================
def EIIMRP9C():
    df = pd.read_parquet(TEMP_DATASET)
    df = df.sort_values(by=["REGION"])
    write_fb_220(df, OUT_9C)


# ==========================================
# EIIMRP9D
# ==========================================
def EIIMRP9D():
    df = pd.read_parquet(TEMP_DATASET)
    df = df.sort_values(by=["REGION", "BRANCH"])
    write_fb_220(df, OUT_9D)


# ==========================================
# MAIN
# ==========================================
def main():

    delete_datasets()

    EIIMRP9A()
    EIIMRP9B()
    EIIMRP9C()
    EIIMRP9D()

    print("EIIELRP9 COMPLETED")


if __name__ == "__main__":
    main()
