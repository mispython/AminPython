import os
import pandas as pd

# ==========================================
# CONFIG (DD mapping)
# ==========================================
CONFIG = {
    "CCRIS": "data/CCRIS.parquet",
    "LN": "data/MNILN.parquet",
    "DBRANCH": "data/BRANCH.txt",   # likely fixed-width
    "ELDS": "data/ELDS.txt",        # likely fixed-width
    "LIST": "data/TEMP_COLDRPT.parquet",
}

OUTPUT = {
    "RPT1A": "EIIMRP1A.txt",
    "RPT1B": "EIIMRP1B.txt",
    "RPT1C": "EIIMRP1C.txt",
    "RPT1D": "EIIMRP1D.txt",
}

RECORD_LENGTH = 220


# ==========================================
# UTIL
# ==========================================
def safe_delete(path):
    if os.path.exists(path):
        os.remove(path)


def write_fixed_width(df, filepath, length=220):
    with open(filepath, "w") as f:
        for _, row in df.iterrows():
            line = "".join(str(x).ljust(20) for x in row)
            line = line[:length].ljust(length)
            f.write(line + "\n")


# ==========================================
# STEP 1 — BUILD BASE DATASET (EIIMRP1A)
# ==========================================
def build_base_dataset():

    ccris = pd.read_parquet(CONFIG["CCRIS"])
    loan = pd.read_parquet(CONFIG["LN"])

    # ⚠️ PLACEHOLDER — real SAS logic needed
    df = ccris.merge(loan, on="ACCTNO", how="inner")

    # Example assumption (NOT FINAL):
    df = df[df["ARREARS"] == 0]

    return df


# ==========================================
# REPORT GENERATORS
# ==========================================
def report_1a(df):
    return df


def report_1b(df):
    return df.sort_values(by=["BRANCH"])


def report_1c(df):
    return df.sort_values(by=["REGION"])


def report_1d(df):
    return df.sort_values(by=["REGION", "BRANCH"])


# ==========================================
# MAIN JOB
# ==========================================
def main():

    # ---- DELETE OLD FILES
    for path in OUTPUT.values():
        safe_delete(path)

    # ---- BUILD BASE (TEMP.COLDRPT)
    base_df = build_base_dataset()

    # Save temp (like LIST DD)
    base_df.to_parquet(CONFIG["LIST"], index=False)

    # ---- GENERATE REPORTS
    write_fixed_width(report_1a(base_df), OUTPUT["RPT1A"])
    write_fixed_width(report_1b(base_df), OUTPUT["RPT1B"])
    write_fixed_width(report_1c(base_df), OUTPUT["RPT1C"])
    write_fixed_width(report_1d(base_df), OUTPUT["RPT1D"])

    print("EIIELRP1 job completed.")


if __name__ == "__main__":
    main()


