# ==========================================================

current = pd.read_parquet(INPUT_DIR / "CURRENT.parquet")
limit_df = pd.read_parquet(INPUT_DIR / "OVERDFT.parquet")

ca = current[current["CURBAL"] < 0].copy()
ca["BALANCE"] = ca["CURBAL"].abs()
ca["DAYSARR"] = 0

od = ca.merge(limit_df, on="ACCTNO", how="left")

product_exclusion = {
    103,104,105,106,107,116,119,120,126,127,128,129,137,138,
    140,141,142,144,145,146,147,148,149,151,154,155,158,
    164,171,172,173,177,178,180,181,182,191,192,193,194,
    195,549,550
}

od = od[
    (od["APPRLIMT"] > 0) &
    (od["LMTAMT"] > 0) &
    (od["USER3"] != "5") &
    (~od["RISKCODE"].isin(["1","2","3","4"])) &
    (~od["ORGCODE"].isin(["001","1"])) &
    (~od["PRODUCT"].isin(product_exclusion))
].copy()

od["CATG"] = "OD"
od["GRADEX"] = np.where(
    od["CRRCODE"].str[0].isin(list("ABCDE")),
    od["CRRCODE"].str[0],
    od["FAACRR"].str[0]
