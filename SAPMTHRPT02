import subprocess
import sys
from pathlib import Path

# ==========================================================
# CONFIG
# ==========================================================

OUTPUT_FILES = [
    "SAP.PBB.DMMISR03.TEXT",
    "SAP.PBB.DMMISR05.TEXT",
    "SAP.PBB.DMMISR06.TEXT",
    "SAP.PBB.DMMISR07.TEXT",
    "SAP.PBB.DMMISR08.TEXT",
    "SAP.PBB.DMMISR10.TEXT",
    "SAP.PBB.MOVE.DP1M",
    "SAP.PBB.FDMISR08.TXT",
    "SAP.PBB.FDMISR09.TXT"
]

SCRIPTS = [
    "dmmisr03.py",
    "dmmisr05.py",
    "dmmisr06.py",
    "dmmisr07.py",
    "dmmisr08.py",
    "dmmisr10.py",
    "dmmisr15.py",
    "fdmisr08.py",
    "fdmisr09.py"
]

OUTPUT_DIR = Path("output")

# ==========================================================
# STEP 1 — DELETE OLD OUTPUT
# ==========================================================

def delete_old_files():
    for filename in OUTPUT_FILES:
        file_path = OUTPUT_DIR / filename
        if file_path.exists():
            file_path.unlink()
            print(f"Deleted {filename}")

# ==========================================================
# STEP 2 — RUN SCRIPTS SEQUENTIALLY
# ==========================================================

def run_scripts():
    for script in SCRIPTS:
        print(f"Running {script}...")
        result = subprocess.run(
            ["python", script],
            capture_output=True,
            text=True
        )

        if result.returncode != 0:
            print(f"Error in {script}")
            print(result.stderr)
            sys.exit(1)

        print(f"{script} completed successfully.")

# ==========================================================
# MAIN
# ==========================================================

if __name__ == "__main__":
    delete_old_files()
    run_scripts()
    print("EIBMRPT2 batch completed.")



