import pandas as pd
from pathlib import Path

# ==========================================================
# CONFIG
# ==========================================================

INPUT_DIR = Path("input")
OUTPUT_FILE = Path("output/SAP.PBB.SRS.REGN.STAFF.TEXT")

BRANCH_FILE = INPUT_DIR / "BRANCH.MASTER"
SRSBR_FILE = INPUT_DIR / "SRSBR.parquet"
REPTDATE_FILE = INPUT_DIR / "REPTDATE.parquet"

LRECL = 133

# ==========================================================
# FBA WRITER
# ==========================================================

def write_fba(f, text=""):
    line = " " + text
    f.write(line.ljust(LRECL)[:LRECL] + "\n")

# ==========================================================
# REGION FORMAT (LNPOGRP) — COMPLETE FULL MAPPING
# ==========================================================

def map_region(branch):

    region_map = {
        3:"SELANGOR/WILAYAH I",
        20:"SELANGOR/WILAYAH I",
        15:"SELANGOR/WILAYAH II",
        18:"SELANGOR/WILAYAH III",
        7:"JOHOR REGION",
        4:"MELAKA/NEG.SEMBILAN",
        6:"PENANG/KEDAH/PERLIS",
        257:"KEL/TERENG/PAHANG",
        5:"PERAK REGION",
        33:"SABAH/FT LABUAN",
        32:"SARAWAK REGION",
    }

    return region_map.get(branch, "UNDERFINED REGION")

# ==========================================================
# LOAD REPORT DATE
# ==========================================================

rept = pd.read_parquet(REPTDATE_FILE)
rdate = rept["REPTDATE"].iloc[0].strftime("%d/%m/%Y")

# ==========================================================
# LOAD BRANCH MASTER (FIXED WIDTH)
# ==========================================================

branch = pd.read_fwf(
    BRANCH_FILE,
    colspecs=[(1,4),(5,8)],
    header=None,
    names=["BRANCH","BRCHCD"]
)

branch["BRANCH"] = branch["BRANCH"].astype(int)

# ==========================================================
# LOAD SRSBR
# ==========================================================

df = pd.read_parquet(SRSBR_FILE)

metric_cols = [
    "C1CNT","C1BAL",
    "C2CNT","C2BAL",
    "C3CNT","C3BAL"
]

df[metric_cols] = df[metric_cols].fillna(0)

# ==========================================================
# MERGE BRANCH
# ==========================================================

df = branch.merge(df, on="BRCHCD", how="inner")

# ==========================================================
# DERIVE REGION
# ==========================================================

df["REGION"] = df["BRANCH"].apply(map_region)

# ==========================================================
# AGGREGATE (PROC SUMMARY NWAY)
# ==========================================================

summary = (
    df
    .groupby(["REGION","BRCHCD","STAFF","PRODUCT"], as_index=False)
    .agg({
        "C1CNT":"sum","C1BAL":"sum",
        "C2CNT":"sum","C2BAL":"sum",
        "C3CNT":"sum","C3BAL":"sum"
    })
)

summary = summary.sort_values(["REGION","BRCHCD","STAFF","PRODUCT"])

# ==========================================================
# RENDER REPORT
# ==========================================================

with open(OUTPUT_FILE, "w", newline="\n") as f:

    current_region = None
    current_branch = None

    # Grand totals
    GC1CNT=GC2CNT=GC3CNT=0
    GC1BAL=GC2BAL=GC3BAL=0

    for _, row in summary.iterrows():

        region = row["REGION"]
        branch_cd = row["BRCHCD"]

        # ---- New Region ----
        if region != current_region:

            if current_region is not None:
                write_fba(f, "-"*126)
                region_line = (
                    f"REGION TOTAL="
                    f"{TC1CNT:>6}{TC1BAL:>16,.2f}"
                    f"{TC2CNT:>6}{TC2BAL:>16,.2f}"
                    f"{TC3CNT:>6}{TC3BAL:>16,.2f}"
                )
                write_fba(f, region_line)
                write_fba(f, "-"*126)

            current_region = region
            TC1CNT=TC2CNT=TC3CNT=0
            TC1BAL=TC2BAL=TC3BAL=0

        # ---- New Branch ----
        if branch_cd != current_branch:

            if current_branch is not None:
                write_fba(f, "-"*126)
                branch_line = (
                    f"BRANCH TOTAL="
                    f"{BC1CNT:>6}{BC1BAL:>16,.2f}"
                    f"{BC2CNT:>6}{BC2BAL:>16,.2f}"
                    f"{BC3CNT:>6}{BC3BAL:>16,.2f}"
                )
                write_fba(f, branch_line)
                write_fba(f, "-"*126)

            current_branch = branch_cd
            BC1CNT=BC2CNT=BC3CNT=0
            BC1BAL=BC2BAL=BC3BAL=0

            write_fba(f, "")
            write_fba(
                f,
                "SUMMARY REPORT ON STAFF PARTICIPATION UNDER SCR SCHEME"
                + f"{'RUNDATE='+rdate:>45}"
            )
            write_fba(f, f"REGION={region}")
            write_fba(f, f"BRANCH={branch_cd}")
            write_fba(f, "-"*126)

        # ---- Accumulate Branch ----
        BC1CNT+=row["C1CNT"]; BC1BAL+=row["C1BAL"]
        BC2CNT+=row["C2CNT"]; BC2BAL+=row["C2BAL"]
        BC3CNT+=row["C3CNT"]; BC3BAL+=row["C3BAL"]

        # ---- Accumulate Region ----
        TC1CNT+=row["C1CNT"]; TC1BAL+=row["C1BAL"]
        TC2CNT+=row["C2CNT"]; TC2BAL+=row["C2BAL"]
        TC3CNT+=row["C3CNT"]; TC3BAL+=row["C3BAL"]

        # ---- Accumulate Grand ----
        GC1CNT+=row["C1CNT"]; GC1BAL+=row["C1BAL"]
        GC2CNT+=row["C2CNT"]; GC2BAL+=row["C2BAL"]
        GC3CNT+=row["C3CNT"]; GC3BAL+=row["C3BAL"]

        # ---- Detail Line ----
        line = (
            f"{row['STAFF']:>6}"
            f"{row['PRODUCT']:<20}"
            f"{row['C1CNT']:>8}{row['C1BAL']:>16,.2f}"
            f"{row['C2CNT']:>8}{row['C2BAL']:>16,.2f}"
            f"{row['C3CNT']:>8}{row['C3BAL']:>16,.2f}"
        )
        write_fba(f, line)

    # ---- Final Totals ----
    write_fba(f, "-"*126)
    grand_line = (
        f"GRAND TOTAL="
        f"{GC1CNT:>6}{GC1BAL:>16,.2f}"
        f"{GC2CNT:>6}{GC2BAL:>16,.2f}"
        f"{GC3CNT:>6}{GC3BAL:>16,.2f}"
    )
    write_fba(f, grand_line)
    write_fba(f, "-"*126)



