    .groupby(["BRANCH","CATG","GRADE"], as_index=False)
    .agg({
        "ACCT":"sum",
        "BALANCE":"sum"
    })
)

# Branch totals
branch_totals = (
    summary
    .groupby("BRANCH", as_index=False)
    .agg({
        "ACCT":"sum",
        "BALANCE":"sum"
    })
    .rename(columns={
        "ACCT":"BRACT",
        "BALANCE":"BRAMT"
    })
)

# ==========================================================
# STEP 3 — MERGE TOTALS
# ==========================================================

summary = summary.merge(branch_totals, on="BRANCH", how="left")

summary["PCACT"] = (
    summary["ACCT"] / summary["BRACT"] * 100
)

summary["PCAMT"] = (
    summary["BALANCE"] / summary["BRAMT"] * 100
)

