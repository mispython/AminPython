# ==========================================================

def map_region(branch):

    region_map = {
        # Only partial shown here — you must complete exactly as SAS
        3: "SELANGOR/WILAYAH I",
        20: "SELANGOR/WILAYAH I",
        15: "SELANGOR/WILAYAH II",
