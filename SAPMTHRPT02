OUTPUT_DIR.mkdir(exist_ok=True)

ACCTS_FILE = INPUT_DIR / "E1271_ACCTS.parquet"
REPTDATE_FILE = INPUT_DIR / "REPTDATE.parquet"

# ==========================================================
# STEP 1 — LOAD REPORT DATE
# ==========================================================

reptdate_df = pd.read_parquet(REPTDATE_FILE)
reptdate = reptdate_df["REPTDATE"].iloc[0]
report_year = reptdate.year

# ==========================================================
# STEP 2 — LOAD ACCOUNT DATA
# ==========================================================

df = pd.read_parquet(ACCTS_FILE)

# ==========================================================
# STEP 3 — FILTER HIGH RISK
# ==========================================================

df = df[df["GRADEX"].isin(["D","E","X"])].copy()

# SAS logic: X becomes blank
df["GRADEX"] = df["GRADEX"].replace({"X": " "})

# ==========================================================
# STEP 4 — SPLIT DATASETS
# ==========================================================

od = df[df["CATG"] == "OD"].copy()
ol = df[df["CATG"] == "OL"].copy()
fl = df[df["CATG"] == "FL"].copy()
hl = df[df["CATG"] == "HL"].copy()

# ==========================================================
# STEP 5 — PROCESS OD & OL
# ==========================================================

def process_overdraft(data):

    if data.empty:
        return data

    data["CURBAL"] = -1 * data["BALANCE"]

    # Convert EXCESSDT numeric YYYYMMDDxxxxx
    def parse_excessdt(val):
        if pd.isna(val) or val == 0:
            return pd.NaT
        val_str = str(int(val)).zfill(11)
        date_part = val_str[:8]
        return pd.to_datetime(date_part, format="%m%d%Y", errors="coerce")

    if "EXCESSDT" in data.columns:
        data["EXCESSD"] = data["EXCESSDT"].apply(parse_excessdt)

    return data[
        [
            "BRANCH","BRCHCD","ACCTNO","NAME",
            "APPRLIMT","CURBAL","GRADEX",
            "CRRCODE","FAACRR","PRODUCT","EXCESSD"
        ]
    ]

od = process_overdraft(od)
ol = process_overdraft(ol)

# ==========================================================
# STEP 6 — PROCESS FL & HL
# ==========================================================

def process_loans(data):

    if data.empty:
        return data

    return data[
        [
            "BRANCH","BRCHCD","ACCTNO","NOTENO",
            "NAME","APPRLIMT","GRADEX",
            "BALANCE","SCORE1","SCORE2",
            "PRODUCT","DAYSARR"
        ]
    ]

fl = process_loans(fl)
hl = process_loans(hl)

# ==========================================================
# STEP 7 — SORT
# ==========================================================

if not od.empty:
    od = od.sort_values(["BRANCH","ACCTNO"])

if not ol.empty:
    ol = ol.sort_values(["BRANCH","ACCTNO"])

if not fl.empty:
    fl = fl.sort_values(["BRANCH","ACCTNO"])

if not hl.empty:
    hl = hl.sort_values(["BRANCH","ACCTNO"])

# ==========================================================
# STEP 8 — EXPORT (Warehouse Equivalent of CPORT)
# ==========================================================

od.to_parquet(OUTPUT_DIR / f"CROD{report_year}.parquet", index=False)
ol.to_parquet(OUTPUT_DIR / f"CROL{report_year}.parquet", index=False)
fl.to_parquet(OUTPUT_DIR / f"CRFL{report_year}.parquet", index=False)
hl.to_parquet(OUTPUT_DIR / f"CRHL{report_year}.parquet", index=False)

print("CRR warehouse extraction complete.")


