import pandas as pd
import numpy as np
from datetime import datetime
from pathlib import Path

# ==========================================================
# CONFIGURATION
# ==========================================================

INPUT_DIR = Path("input")
OUTPUT_DIR = Path("output")
OUTPUT_DIR.mkdir(exist_ok=True)

# ----------------------------------------------------------
# Utility: Fixed-width writer (FB LRECL=80)
# ----------------------------------------------------------

def write_fixed_width_crr(df: pd.DataFrame, output_file: Path):
    with open(output_file, "w", newline="\n") as f:
        for _, row in df.iterrows():
            line = (
                f"{int(row.BRANCH):>3}"
                f"  "
                f"{row.GRADEX:<1}"
                f" "
                f"{row.CATG:<2}"
                f"  "
                f"{int(row.ACCT):>8}"
                f"  "
                f"{row.BALANCE:>12.2f}"
            )
            f.write(line.ljust(80)[:80] + "\n")


# ==========================================================
# STEP 1 — LOAD REPORT DATE
# ==========================================================

reptdate_df = pd.read_parquet(INPUT_DIR / "REPTDATE.parquet")
reptdate = reptdate_df["REPTDATE"].iloc[0]

day = reptdate.day
month = reptdate.month
year = reptdate.year

if day == 8:
    week = "1"
    sdd = 1
elif day == 15:
    week = "2"
    sdd = 9
elif day == 22:
    week = "3"
    sdd = 16
else:
    week = "4"
    sdd = 23

sdate = datetime(year, month, day)

loan_dataset_name = f"LOAN{month:02d}{week}"

# ==========================================================
