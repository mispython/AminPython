import os
import pandas as pd
from datetime import datetime

# ================================
# CONFIG (simulate DD names)
# ================================
INPUT_CCRISP_LOAN = "CCRISP_LOAN.txt"
INPUT_CCRISP_OVERDFS = "CCRISP_OVERDFS.txt"

INPUT_CCRISI_LOAN = "CCRISI_LOAN.txt"
INPUT_CCRISI_OVERDFS = "CCRISI_OVERDFS.txt"

OUTPUT_DLFTP = "DLFTP.txt"
OUTPUT_IDLFTP = "IDLFTP.txt"

RECORD_LENGTH = 80


# ================================
# UTIL: FIXED WIDTH WRITER
# ================================
def write_fixed_width(df, filepath, record_length=80):
    with open(filepath, "w") as f:
        for _, row in df.iterrows():
            line = "".join(str(val).ljust(10) for val in row)
            line = line[:record_length].ljust(record_length)
            f.write(line + "\n")


# ================================
# UTIL: DELETE FILE IF EXISTS
# ================================
def safe_delete(filepath):
    if os.path.exists(filepath):
        os.remove(filepath)


# ================================
# CORE TRANSFORMATION
# ================================
def process_system(loan_path, overdraft_path):
    # ---- LOAD (assume structured text, adjust if fixed-width later)
    loan = pd.read_csv(loan_path)
    overdraft = pd.read_csv(overdraft_path)

    # ---- LOAN
    loan = loan.rename(columns={"LOANTYPE": "PRODUCT"})
    loan = loan[loan["LEG"] == "A"]

    # ---- OVERDRAFT
    overdraft["NOTENO"] = 0
    overdraft = overdraft[overdraft["LEG"] == "A"]

    # ---- COMBINE
    df = pd.concat([loan, overdraft], ignore_index=True)

    # ---- KEEP FIELDS
    df = df[["BRANCH", "PRODUCT", "ACCTNO", "NOTENO", "DELQCD", "COSTCTR"]]

    # ---- SORT
    df = df.sort_values(by=["ACCTNO", "NOTENO"])

    # ---- HANDLE MISSING (SAS MISSING=0)
    df = df.fillna(0)

    return df


# ================================
# MAIN JOB
# ================================
def main():

    # ---- DELETE EXISTING
    safe_delete(OUTPUT_DLFTP)
    safe_delete(OUTPUT_IDLFTP)

    # ---- PROCESS PBB
    pbb_df = process_system(INPUT_CCRISP_LOAN, INPUT_CCRISP_OVERDFS)

    # ---- PROCESS PIBB
    pibb_df = process_system(INPUT_CCRISI_LOAN, INPUT_CCRISI_OVERDFS)

    # ---- WRITE FIXED WIDTH
    write_fixed_width(pbb_df, OUTPUT_DLFTP, RECORD_LENGTH)
    write_fixed_width(pibb_df, OUTPUT_IDLFTP, RECORD_LENGTH)

    print("Job EIBWDELQ completed successfully.")


if __name__ == "__main__":
    main()


