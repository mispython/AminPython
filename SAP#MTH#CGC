import pandas as pd
import numpy as np
from datetime import datetime

# ================================
# FIXED WIDTH READERS
# ================================
def read_crft(file_path):
    colspecs = [
        (0,1),    # RECTYP1
        (3,11),   # TFID
        (11,16),  # SUBACCT
        (364,365),# PREIND
        (367,368),# CENSUST
        (376,386) # ACCTNO
    ]
    
    df = pd.read_fwf(file_path, colspecs=colspecs,
                     names=["RECTYP1","TFID","SUBACCT","PREIND","CENSUST","ACCTNO"])
    
    df = df[df["RECTYP1"] != '1']
    df = df[df["CENSUST"] >= 0]
    
    return df


# ================================
# ARREARS CALCULATION
# ================================
def calculate_arrears(df, report_date):
    df["NODAYS"] = 0
    df["ARREARS"] = 0

    mask = (df["MATUREDS"] > 0) & (report_date > df["MATUREDS"])

    df.loc[mask, "NODAYS"] = (report_date - df["MATUREDS"]) + 1

    df["ARREARS"] = (df["NODAYS"] / 30).astype(int)

    # special rule
    df.loc[df["ARREARS"] == 24, "ARREARS"] = (
        df["NODAYS"] / 30
    ).round()

    return df


# ================================
# NPL LOGIC
# ================================
def apply_npl_logic(df):
    df["CVAR12"] = ""
    df["CVAR13"] = ""

    mask = df["NODAYS"] > 89

    df.loc[mask, "CVAR12"] = "NPL"
    df.loc[mask, "NPLDATE"] = df["MATUREDS"] + 89

    # format date
    df["CVAR13"] = pd.to_datetime(df["NPLDATE"], errors="coerce")\
        .dt.strftime("%d/%m/%Y")

    return df


# ================================
# MAIN PIPELINE
# ================================
def main():

    crft = read_crft("CRFTABL.txt")

    mast = pd.read_parquet("MAST.parquet")
    cred = pd.read_parquet("CRED.parquet")
    prov = pd.read_parquet("PROV.parquet")

    # ---- merge
    df = crft.merge(mast, on="ACCTNO")

    # ---- credit aggregation
    cred1 = cred.groupby("ACCTNO")["OUTSTAND"].sum().reset_index()

    # ---- join
    df = df.merge(cred1, on="ACCTNO", how="left")

    # ---- arrears logic
    report_date = 20250101  # replace properly
    df = calculate_arrears(df, report_date)

    # ---- NPL
    df = apply_npl_logic(df)

    # ---- final mapping
    df["CVAR01"] = df["CENSUST"]
    df["CVAR06"] = df["ACCTNO"]
    df["CVAR09"] = df["OUTSTAND"]
    df["CVAR11"] = df["ARREARS"]

    df = df[df["OUTSTAND"].notna()]

    df.to_parquet("BTNPGX.parquet", index=False)


if __name__ == "__main__":
    main()

