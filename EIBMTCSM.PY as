def packed_decimal(raw: bytes, scale: int = 0) -> Decimal | None:
    """Decode a mainframe packed-decimal value (SAS PD informat)."""
    if not raw or all(byte == 0 for byte in raw):
        return None
    nibbles = [nibble for byte in raw for nibble in (byte >> 4, byte & 0x0F)]
    sign = -1 if nibbles.pop() in (0x0B, 0x0D) else 1
    if any(nibble > 9 for nibble in nibbles):
        return None
    value = Decimal("".join(map(str, nibbles)))
    return sign * value.scaleb(-scale)


def binary_integer(raw: bytes) -> int | None:
    """Decode a mainframe big-endian signed integer (SAS IB informat)."""
    return int.from_bytes(raw, byteorder="big", signed=True) if raw else None


def decoded(raw: bytes, encoding: str) -> str:
    return raw.decode(encoding, errors="replace").strip()


def numeric_text(raw: bytes, encoding: str) -> int | None:
    value = decoded(raw, encoding)
    return int(value) if value else None


def transaction_date(value: Decimal | None) -> str:
    if value is None:
        return ""
    digits = str(abs(int(value))).zfill(8)[-8:]
    try:
        return datetime.strptime(digits, "%Y%m%d").date().isoformat()
    except ValueError:
        return ""


def parse_record(record: bytes, encoding: str) -> dict[str, object]:
    if len(record) < 168:
        raise ValueError(f"Record is only {len(record)} bytes; expected at least 168")

    trnxdt = packed_decimal(record[0:5])
    trnxtime = packed_decimal(record[5:9])
    branch = packed_decimal(record[11:14])
    trnxcode = binary_integer(record[18:20])
    compind = decoded(record[37:38], encoding)
    authind = decoded(record[38:39], encoding)

    return {
        "CARDNO": decoded(record[70:90], encoding),
        "BRANCH": int(branch) if branch is not None else None,
        "TERMNO": binary_integer(record[14:18]),
        "TRNXTIME": str(int(trnxtime)).zfill(6) if trnxtime is not None else "",
        "TRNXCODE": trnxcode,
        "ATMTYPE": numeric_text(record[9:11], encoding),
        "TRNXAMT": float(packed_decimal(record[20:28], 2) or 0),
        "SUCCESS_TRAN_AMT": float(packed_decimal(record[28:36], 2) or 0),
        "DENIAL_CD": numeric_text(record[46:49], encoding),
        "CARDTYPE": decoded(record[54:56], encoding),
        "ACCTNO": decoded(record[90:106], encoding),
        "STATE_CD": decoded(record[166:168], encoding),
        "TRNXTYPE": TYPE_FORMAT.get(trnxcode, ""),
        "TRNXDATE": transaction_date(trnxdt),
        "TRNXSTAT": "S" if compind == "S" and authind == "A" else "R",
    }


def read_records(path: Path, record_length: int | None) -> list[bytes]:
    if not path.is_file():
        raise FileNotFoundError(f"Missing input file: {path}")
    content = path.read_bytes()
    if record_length:
        if len(content) % record_length:
            raise ValueError("Input size is not divisible by --record-length")
        return [
            content[offset:offset + record_length]
            for offset in range(0, len(content), record_length)
        ]
    return [record.rstrip(b"\r") for record in content.split(b"\n") if record.strip()]


def parse_date(value: str) -> date:
    try:
        return datetime.strptime(value, "%Y-%m-%d").date()
    except ValueError as error:
        raise argparse.ArgumentTypeError("date must be YYYY-MM-DD") from error


def write_sas7bdat(output_dir: Path, tables: dict[str, pd.DataFrame]) -> dict[str, Path]:
    """Write DataFrames as SAS7BDAT through the configured SAS runtime."""
    try:
        import saspy
    except ImportError as error:
        raise RuntimeError(
            "Writing SAS7BDAT requires saspy and a configured SAS runtime"
        ) from error

    output_dir.mkdir(parents=True, exist_ok=True)
    sas = saspy.SASsession()
    try:
        sas_path = str(output_dir.resolve()).replace("'", "''")
        result = sas.submit(f"libname OUT '{sas_path}';")
        if "ERROR:" in result.get("LOG", ""):
            raise RuntimeError(result["LOG"])
        for table, frame in tables.items():
            sas.df2sd(frame, table=table, libref="OUT")
    finally:
        sas.endsas()

    return {table: output_dir / f"{table}.sas7bdat" for table in tables}

def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--input", type=Path, default=DEFAULT_INPUT)
    parser.add_argument("--output-dir", type=Path, default=DEFAULT_OUTPUT_DIR)
    parser.add_argument(
        "--report-date", type=parse_date,
        default=date.today().replace(day=1) - timedelta(days=1),
    )
    parser.add_argument("--encoding", default="cp037")
    parser.add_argument(
        "--record-length",
        type=int,
        help="fixed record length; omit when records are newline-delimited",
    )
    args = parser.parse_args()

    rows = [
        parse_record(record, args.encoding)
        for record in read_records(args.input, args.record_length)
    ]
    transactions = pd.DataFrame(rows)
    cash = transactions[
        (transactions["TRNXSTAT"] == "S")
        & transactions["CARDTYPE"].isin(["00", "02", "03", "04"])
        & transactions["TRNXCODE"].isin([1, 2, 129])
    ][["TRNXDATE", "TRNXTIME", "CARDNO", "TRNXAMT", "TRNXTYPE"]]

    month, year2 = args.report_date.strftime("%m"), args.report_date.strftime("%y")
    full_table = f"ATMTRNX{month}{year2}"
    cash_table = f"ATM_CASH{args.report_date:%Y%m}"
    outputs = write_sas7bdat(
        args.output_dir, {full_table: transactions, cash_table: cash}
    )

    print(f"Input       : {args.input}")
    print(f"Rows input  : {len(transactions):,}")
    print(f"ATMTRNX     : {outputs[full_table]}")
    print(f"ATM_CASH    : {outputs[cash_table]}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())





