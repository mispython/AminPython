"""
EIIMFGP3 - Islamic GP3 Fix Job
Converted from SAS Job EIIMFGP3

Purpose:
- Update Loan and Deposit tables with GP3 risk data
- Merge overdraft limits into loan file
"""

import pandas as pd
from pathlib import Path
import sys


# ============================================================
# CONFIG
# ============================================================

DATA_DIR = Path("data_pibb")
OUTPUT_DIR = Path("data_pibb")   # Overwrite source (like SAS)
OUTPUT_DIR.mkdir(exist_ok=True)


# ============================================================
# STEP 1 — DERIVE REPORTING CONTEXT
# ============================================================

def derive_reporting_context():

    reptdate_df = pd.read_parquet(DATA_DIR / "deposit_reptdate.parquet")
    reptdate = pd.to_datetime(reptdate_df.iloc[0]["REPTDATE"])

    day = reptdate.day

    if 1 <= day <= 8:
        wk = "1"
    elif 9 <= day <= 15:
        wk = "2"
    elif 16 <= day <= 22:
        wk = "3"
    else:
        wk = "4"

    return {
        "NOWK": wk,
        "REPTMON": f"{reptdate.month:02}",
        "REPTYEAR": str(reptdate.year)
    }


# ============================================================
# STEP 2 — LOAD GP3
# ============================================================

def load_gp3():

    gp3 = pd.read_parquet(DATA_DIR / "limit_gp3.parquet")

    gp3["RISKRTE"] = pd.to_numeric(gp3["RISKCODE"], errors="coerce")
    gp3["EXODDATE"] = gp3["EXCESSDT"]
    gp3["TEMPODDT"] = gp3["TODDATE"]
    gp3["ODSTAT"] = gp3["ODSTATUS"]
    gp3["RISKCD"] = gp3["RISKCODE"]

    return gp3


# ============================================================
# STEP 3 — UPDATE LOAN FILE
# ============================================================

def update_loan(context, gp3):

    loan_file = DATA_DIR / f"loan_{context['REPTMON']}{context['NOWK']}.parquet"
    loan = pd.read_parquet(loan_file)

    gp3_subset = gp3[["ACCTNO", "RISKRTE", "RISKCD"]]

    updated = loan.merge(gp3_subset, on="ACCTNO", how="left")

    updated["RISKRTE"] = updated["RISKRTE_y"].combine_first(updated.get("RISKRTE_x"))
    updated["RISKCD"] = updated["RISKCD_y"].combine_first(updated.get("RISKCD_x"))

    updated = updated.drop(columns=[c for c in updated.columns if c.endswith("_x") or c.endswith("_y")])

    updated.to_parquet(loan_file, index=False)

    return updated


# ============================================================
# STEP 4 — UPDATE DEPOSIT CURRENT
# ============================================================

def update_deposit_current(gp3):

    deposit_file = DATA_DIR / "deposit_current.parquet"
    deposit = pd.read_parquet(deposit_file)

    gp3_subset = gp3[["ACCTNO", "EXODDATE", "TEMPODDT", "ODSTAT", "RISKCODE"]]

    updated = deposit.merge(gp3_subset, on="ACCTNO", how="left")

    updated.to_parquet(deposit_file, index=False)

    return updated


# ============================================================
# STEP 5 — MERGE OVERDRAFT LIMIT
# ============================================================

def merge_overdraft_limit(context):

    loan_file = DATA_DIR / f"loan_{context['REPTMON']}{context['NOWK']}.parquet"
    loan = pd.read_parquet(loan_file)

    deposit = pd.read_parquet(DATA_DIR / "deposit_current.parquet")
    overdraft = pd.read_parquet(DATA_DIR / "limit_overdft.parquet")

    # Filter overdrawn current accounts
    current = deposit[
        (~deposit["OPENIND"].isin(["B", "C", "P"])) &
        (deposit["CURBAL"] < 0)
    ]

    overdraft = overdraft.rename(columns={"APPRLIMT": "APPRLIM2"})
    overdraft = overdraft.drop_duplicates(subset=["ACCTNO"])

    overdraft_merge = current[["ACCTNO"]].merge(
        overdraft[["ACCTNO", "APPRLIM2"]],
        on="ACCTNO",
        how="left"
    )

    loan_updated = loan.merge(overdraft_merge, on="ACCTNO", how="left")

    loan_updated["APPRLIM2"] = loan_updated["APPRLIM2"].fillna(0)

    loan_updated.to_parquet(loan_file, index=False)


# ============================================================
# MAIN
# ============================================================

def main():

    print("=== EIIMFGP3 STARTED ===")

    context = derive_reporting_context()
    print("Context:", context)

    gp3 = load_gp3()

    update_loan(context, gp3)
    update_deposit_current(gp3)
    merge_overdraft_limit(context)

    print("=== EIIMFGP3 COMPLETED SUCCESSFULLY ===")


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print("JOB FAILED:", str(e))
        sys.exit(77)


