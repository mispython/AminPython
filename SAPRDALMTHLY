%MACRO PROCESS;
  %IF "&LOAN"="&RDATE" AND
      "&DEPOSIT"="&RDATE" AND
      "&FD"="&RDATE" AND
      "&KAPITI1"="&RDATE" AND
      "&KAPITI2"="&RDATE" AND
      "&KAPITI3"="&RDATE" %THEN %DO;

      /*** REPORT ON DOMESTIC ASSETS AND LIABILITIES ***/
      %INC PGM(DALMPBBD);
      %INC PGM(DALWBP);
      %INC PGM(DALMBP);
  /*  %INC PGM(DEPMPBBD); */
      PROC COPY IN=BNM OUT=DEPOBACK;
        SELECT SAVG&REPTMON&NOWK
               CURN&REPTMON&NOWK
