"""
EIBM1241 - FISS P124 RDAL Reporting
Converted from SAS Job EIBM1241

Purpose:
- Generate final P124 RDAL output file (FISS version)
"""

import pandas as pd
from datetime import datetime
from pathlib import Path
import sys


# ============================================================
# CONFIG
# ============================================================

DATA_DIR = Path("data_pibb")
REF_DIR = Path("data_reference")
OUTPUT_DIR = Path("output_fiss")
OUTPUT_DIR.mkdir(exist_ok=True)

OUTPUT_FILE = OUTPUT_DIR / "FISS_RDAL124.txt"


# ============================================================
# STEP 1 — REPORTING CONTEXT
# ============================================================

def derive_reporting_context():

    reptdate_df = pd.read_parquet(DATA_DIR / "loan_reptdate.parquet")
    reptdate = pd.to_datetime(reptdate_df.iloc[0]["REPTDATE"])

    month = reptdate.month
    year = reptdate.year

    return {
        "REPTMON": f"{month:02}",
        "REPTYEAR": str(year),
        "RDATE": reptdate.strftime("%d%m%Y")
    }


# ============================================================
# STEP 2 — LOAD DATA
# ============================================================

def load_data():

    current_loan = pd.read_parquet(DATA_DIR / "loan_master.parquet")
    prior_loan = pd.read_parquet(DATA_DIR / "loan_master_prior.parquet")
    p124_reference = pd.read_parquet(REF_DIR / "p124_reference.parquet")

    return current_loan, prior_loan, p124_reference


# ============================================================
# STEP 3 — APPLY P124 CLASSIFICATION
# ============================================================

def apply_p124_classification(current_df, reference_df):

    # Example join by product code
    classified = current_df.merge(
        reference_df,
        on="PRODUCT_CODE",
        how="left"
    )

    classified["P124_CLASS"] = classified["P124_CLASS"].fillna("UNCLASSIFIED")

    return classified


# ============================================================
# STEP 4 — CALCULATE MOVEMENT
# ============================================================

def calculate_movement(current_df, prior_df):

    merged = current_df.merge(
        prior_df[["ACCTNO", "OUTSTANDING"]],
        on="ACCTNO",
        how="left",
        suffixes=("", "_PRIOR")
    )

    merged["OUTSTANDING_PRIOR"] = merged["OUTSTANDING_PRIOR"].fillna(0)

    merged["MOVEMENT"] = (
        merged["OUTSTANDING"] -
        merged["OUTSTANDING_PRIOR"]
    )

    return merged


# ============================================================
# STEP 5 — AGGREGATE BY CLASS
# ============================================================

def aggregate_p124(df):

    summary = (
        df.groupby("P124_CLASS")
        .agg({
            "OUTSTANDING": "sum",
            "MOVEMENT": "sum"
        })
        .reset_index()
    )

    return summary


# ============================================================
# STEP 6 — WRITE FIXED-WIDTH RDAL OUTPUT
# ============================================================

def write_rdal_file(summary_df, context):

    with open(OUTPUT_FILE, "w") as f:

        header = f"FISS P124 RDAL REPORT     DATE: {context['RDATE']}\n"
        f.write(header)
        f.write("-" * 80 + "\n")

        for _, row in summary_df.iterrows():

            line = (
                f"{row['P124_CLASS']:<20}"
                f"{row['OUTSTANDING']:>20,.2f}"
                f"{row['MOVEMENT']:>20,.2f}"
            )

            f.write(line + "\n")

    print("RDAL124 file written:", OUTPUT_FILE)


# ============================================================
# MAIN ORCHESTRATOR
# ============================================================

def main():

    print("=== EIBM1241 STARTED ===")

    context = derive_reporting_context()
    print("Context:", context)

    current_loan, prior_loan, reference = load_data()

    classified = apply_p124_classification(current_loan, reference)

    movement_df = calculate_movement(classified, prior_loan)

    summary = aggregate_p124(movement_df)

    write_rdal_file(summary, context)

    print("=== EIBM1241 COMPLETED SUCCESSFULLY ===")


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print("JOB FAILED:", str(e))
        sys.exit(77)

