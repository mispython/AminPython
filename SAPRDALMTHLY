"""
EIBMP124 - Islamic P124 Regulatory Reporting
Converted from SAS Job EIBMP124

Purpose:
- Generate P124 loan regulatory report
- Compare current vs prior loan snapshot
- Output fixed-width RDAL124 file
"""

import pandas as pd
from datetime import datetime
from pathlib import Path
import sys


# ============================================================
# CONFIG
# ============================================================

DATA_DIR = Path("data_pibb")
OUTPUT_DIR = Path("output_p124")
OUTPUT_DIR.mkdir(exist_ok=True)

OUTPUT_FILE = OUTPUT_DIR / "RDAL124.txt"


# ============================================================
# STEP 1 — DERIVE REPORTING CONTEXT
# ============================================================

def derive_reporting_context():

    reptdate_df = pd.read_parquet(DATA_DIR / "loan_reptdate.parquet")
    reptdate = pd.to_datetime(reptdate_df.iloc[0]["REPTDATE"])

    day = reptdate.day

    if day == 8:
        wk = "1"
    elif day == 15:
        wk = "2"
    elif day == 22:
        wk = "3"
    else:
        wk = "4"

    month = reptdate.month
    year = reptdate.year

    # prior month
    if month == 1:
        prior_month = 12
        prior_year = year - 1
    else:
        prior_month = month - 1
        prior_year = year

    return {
        "NOWK": wk,
        "REPTMON": f"{month:02}",
        "REPTYEAR": str(year),
        "PRIOR_MON": f"{prior_month:02}",
        "PRIOR_YEAR": str(prior_year),
        "RDATE": reptdate.strftime("%d%m%Y")
    }


# ============================================================
# STEP 2 — LOAD LOAN SNAPSHOTS
# ============================================================

def load_loan_data(context):

    current_loan = pd.read_parquet(DATA_DIR / "loan_master.parquet")
    prior_loan = pd.read_parquet(DATA_DIR / "loan_master_prior.parquet")

    return current_loan, prior_loan


# ============================================================
# STEP 3 — P124 CALCULATION LOGIC
# ============================================================

def calculate_p124(current_df, prior_df):

    # Example: compare exposure movement
    merged = current_df.merge(
        prior_df,
        on="ACCTNO",
        how="left",
        suffixes=("_CUR", "_PRIOR")
    )

    merged["EXPOSURE_MOVEMENT"] = (
        merged["OUTSTANDING_CUR"] -
        merged["OUTSTANDING_PRIOR"].fillna(0)
    )

    # Placeholder for P124 classification mapping
    merged["P124_CLASS"] = "STANDARD"

    return merged


# ============================================================
# STEP 4 — FORMAT OUTPUT FILE
# ============================================================

def write_p124_report(df, context):

    with open(OUTPUT_FILE, "w") as f:

        header = f"P124 ISLAMIC REPORT     DATE: {context['RDATE']}\n"
        f.write(header)
        f.write("-" * 100 + "\n")

        for _, row in df.iterrows():

            line = (
                f"{row['ACCTNO']:<15}"
                f"{row['P124_CLASS']:<15}"
                f"{row['OUTSTANDING_CUR']:>15,.2f}"
                f"{row['EXPOSURE_MOVEMENT']:>15,.2f}"
            )

            f.write(line + "\n")

    print("P124 report written to:", OUTPUT_FILE)


# ============================================================
# MAIN ORCHESTRATOR
# ============================================================

def main():

    print("=== EIBMP124 STARTED ===")

    context = derive_reporting_context()
    print("Context:", context)

    current_loan, prior_loan = load_loan_data(context)

    p124_df = calculate_p124(current_loan, prior_loan)

    write_p124_report(p124_df, context)

    print("=== EIBMP124 COMPLETED SUCCESSFULLY ===")


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print("JOB FAILED:", str(e))
        sys.exit(77)

