"""
EIBMTHLS - FOREX & DCI Monthly Extraction
Converted from SAS Job EIBMTHLS

Purpose:
- Extract FOREX and DCI transactions
- Output control-delimited text file
- Mimic SAS formatted output
"""

import pandas as pd
from datetime import datetime, timedelta
from pathlib import Path
import sys


# ============================================================
# CONFIG
# ============================================================

DATA_DIR = Path("data_pbb")
OUTPUT_DIR = Path("output_forex")
OUTPUT_DIR.mkdir(exist_ok=True)

DELIM = "\x05"   # ASCII 05 hex (same as SAS '05'X)


BIC_CODES = {
    '57210','57299','57510','57599','57610','57620','57631',
    '57632','57633','57639','57711','57712','57720','57730',
    '57799','57110','57120','57130','57200','57410','57420',
    '57430','57500','68504','78504'
}


# ============================================================
# STEP 1 — DERIVE REPORTING DATE
# ============================================================

def derive_reporting_context():

    today = datetime.today()
    reptdate = today - timedelta(days=today.day)

    return {
        "REPTMON": f"{reptdate.month:02}",
        "REPTDT": reptdate.strftime("%y%m%d"),
        "REPTDATE_OBJ": reptdate
    }


# ============================================================
# STEP 2 — LOAD AND FILTER DATA
# ============================================================

def load_forex_data(context):

    k1 = pd.read_parquet(DATA_DIR / f"K1TBL{context['REPTMON']}.parquet")
    dci = pd.read_parquet(DATA_DIR / f"DCITBL{context['REPTMON']}.parquet")

    df = pd.concat([k1, dci], ignore_index=True)

    df = df[df["BNMCODE"].str[:5].isin(BIC_CODES)]

    return df


# ============================================================
# STEP 3 — WRITE OUTPUT FILE
# ============================================================

def write_output(df, context):

    filename = OUTPUT_DIR / f"FOREX_DCI_{context['REPTMON']}.XLS"

    with open(filename, "w", encoding="utf-8") as f:

        f.write("PUBLIC BANK BERHAD\n")
        f.write("DETAIL FOREX AND DCI TRANSACTIONS\n\n")
        f.write("(A) Total Commitments & Contingencies\n\n")

        for bnmcode, group in df.groupby("BNMCODE"):

            f.write(f"BNMCODE={bnmcode}\n")

            total_amt = 0
            recno = 0

            for _, row in group.iterrows():

                recno += 1
                amount = abs(row.get("AMOUNT", 0))
                total_amt += amount

                if row.get("DCDLP") in ("DCI", "RFO", "TFO", "PFO"):

                    line = DELIM.join([
                        str(recno),
                        context["REPTDATE_OBJ"].strftime("%d/%m/%Y"),
                        str(row.get("DCDLP","")),
                        str(row.get("DCDLR","")),
                        str(row.get("DCCUS","")),
                        str(row.get("DCCLC","")),
                        str(row.get("DCBCCY","")),
                        f"{row.get('DCIAMT',amount):,.2f}",
                        f"{row.get('C8SPT',0):.7f}",
                        f"{amount:,.2f}",
                        str(row.get("DCACCY","")),
                        str(row.get("GFCTP","")),
                        str(row.get("GFCUN","")),
                        str(row.get("GFCNAL","")),
                        str(row.get("DCTRNT","")),
                        str(row.get("DCBSI","")),
                        str(row.get("ODGRP","")),
                        str(row.get("STATUS","")),
                        str(row.get("DCCTRD","")),
                        str(row.get("DCMTYD","")),
                        str(row.get("CUSTCD","")),
                        str(row.get("OPTYPE","")),
                        str(row.get("STKRATE",""))
                    ])

                else:

                    line = DELIM.join([
                        str(recno),
                        f"{row.get('GWBALA',0):,.2f}",
                        f"{amount:,.2f}",
                        str(row.get("GWSHN","")),
                        str(row.get("GWCTP","")),
                        str(row.get("GWCNAL","")),
                        str(row.get("GWCCY","")),
                        str(row.get("GWCNAP","")),
                        str(row.get("GWDLP","")),
                        str(row.get("GWDLR","")),
                        str(row.get("GWSDT","")),
                        str(row.get("GWMVT","")),
                        str(row.get("GWMVTS","")),
                        str(row.get("GWC2R","")),
                        str(row.get("GWOCY","")),
                        str(row.get("GWCBD",""))
                    ])

                f.write(line + "\n")

            f.write(DELIM + "TOTAL" + DELIM + f"{total_amt:,.2f}\n\n")

    print("File written:", filename)


# ============================================================
# MAIN
# ============================================================

def main():

    print("=== EIBMTHLS STARTED ===")

    context = derive_reporting_context()
    print("Context:", context)

    df = load_forex_data(context)

    write_output(df, context)

    print("=== EIBMTHLS COMPLETED SUCCESSFULLY ===")


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print("JOB FAILED:", str(e))
        sys.exit(77)


