========================================== JOB 1 : EIBMFGP3 ========================================== 				



import pandas as pd
from datetime import datetime
from pathlib import Path


# ============================================================
# CONFIGURATION
# ============================================================

DATA_DIR = Path("data")
OUTPUT_DIR = Path("output")
OUTPUT_DIR.mkdir(exist_ok=True)

LOAN_FILE = DATA_DIR / "loan_weekly.parquet"
CURRENT_FILE = DATA_DIR / "deposit_current.parquet"
GP3_FILE = DATA_DIR / "limit_gp3.parquet"
OVERDFT_FILE = DATA_DIR / "limit_overdraft.parquet"
REPTDATE_FILE = DATA_DIR / "deposit_reptdate.parquet"


# ============================================================
# STEP 1 — DERIVE REPORTING CONTEXT
# ============================================================

def derive_reporting_context(reptdate_df: pd.DataFrame) -> dict:
    reptdate = pd.to_datetime(reptdate_df.iloc[0]["REPTDATE"])

    day = reptdate.day

    if 1 <= day <= 8:
        nowk = "1"
    elif 9 <= day <= 15:
        nowk = "2"
    elif 16 <= day <= 22:
        nowk = "3"
    else:
        nowk = "4"

    return {
        "NOWK": nowk,
        "REPTYEAR": reptdate.year,
        "REPTMON": f"{reptdate.month:02}",
        "REPTDAY": f"{reptdate.day:02}",
        "RDATE": reptdate.strftime("%d%m%Y"),
    }


# ============================================================
# STEP 2 — PREPARE GP3 DATA
# ============================================================

def prepare_gp3(gp3_df: pd.DataFrame) -> pd.DataFrame:
    df = gp3_df.copy()

    # Convert risk code (1st digit)
    df["RISKRTE"] = df["RISKCODE"].astype(str).str[0].astype(float)

    # Map fields
    df["EXODDATE"] = df["EXCESSDT"]
    df["TEMPODDT"] = df["TODDATE"]
    df["ODSTAT"] = df["ODSTATUS"]

    return df.sort_values("ACCTNO")


# ============================================================
# STEP 3 — UPDATE LOAN WITH RISK
# ============================================================

def update_loan_with_risk(loan_df: pd.DataFrame,
                          gp3_df: pd.DataFrame) -> pd.DataFrame:

    merged = loan_df.merge(
        gp3_df[["ACCTNO", "RISKRTE", "RISKCD"]],
        on="ACCTNO",
        how="left"
    )

    return merged


# ============================================================
# STEP 4 — UPDATE CURRENT ACCOUNT WITH OD INFO
# ============================================================

def update_current_with_gp3(current_df: pd.DataFrame,
                            gp3_df: pd.DataFrame) -> pd.DataFrame:

    merged = current_df.merge(
        gp3_df[
            ["ACCTNO", "EXODDATE", "TEMPODDT",
             "ODSTAT", "RISKCODE"]
        ],
        on="ACCTNO",
        how="left"
    )

    return merged


# ============================================================
# STEP 5 — APPLY OVERDRAFT LIMIT TO LOAN
# ============================================================

def apply_overdraft_limit(
        loan_df: pd.DataFrame,
        current_df: pd.DataFrame,
        overdraft_df: pd.DataFrame
) -> pd.DataFrame:

    # Filter negative current accounts
    negative_current = current_df[
        (~current_df["OPENIND"].isin(["B", "C", "P"])) &
        (current_df["CURBAL"] < 0)
    ]

    # Remove duplicates from overdraft
    overdraft_clean = (
        overdraft_df
        .drop_duplicates(subset=["ACCTNO"])
        .rename(columns={"APPRLIMT": "APPRLIM2"})
    )

    # Merge overdraft limit to negative accounts
    negative_with_limit = negative_current.merge(
        overdraft_clean[["ACCTNO", "APPRLIM2"]],
        on="ACCTNO",
        how="left"
    )

    negative_with_limit["APPRLIM2"] = \
        negative_with_limit["APPRLIM2"].fillna(0)

    # Merge APPRLIM2 back into loan
    loan_updated = loan_df.merge(
        negative_with_limit[["ACCTNO", "APPRLIM2"]],
        on="ACCTNO",
        how="left"
    )

    loan_updated["APPRLIM2"] = \
        loan_updated["APPRLIM2"].fillna(0)

    return loan_updated


# ============================================================
# MAIN EXECUTION
# ============================================================

def main():

    print("=== EIBMFGP3 STARTED ===")

    # Load data
    loan_df = pd.read_parquet(LOAN_FILE)
    current_df = pd.read_parquet(CURRENT_FILE)
    gp3_df = pd.read_parquet(GP3_FILE)
    overdraft_df = pd.read_parquet(OVERDFT_FILE)
    reptdate_df = pd.read_parquet(REPTDATE_FILE)

    # Derive context
    context = derive_reporting_context(reptdate_df)
    print("Reporting Context:", context)

    # Prepare GP3
    gp3_prepared = prepare_gp3(gp3_df)

    # Update Loan
    loan_updated = update_loan_with_risk(
        loan_df,
        gp3_prepared
    )

    # Update Current
    current_updated = update_current_with_gp3(
        current_df,
        gp3_prepared
    )

    # Apply overdraft logic
    final_loan = apply_overdraft_limit(
        loan_updated,
        current_updated,
        overdraft_df
    )

    # Save outputs
    final_loan.to_parquet(
        OUTPUT_DIR / "loan_updated.parquet",
        index=False
    )

    current_updated.to_parquet(
        OUTPUT_DIR / "current_updated.parquet",
        index=False
    )

    print("=== EIBMFGP3 COMPLETED SUCCESSFULLY ===")


if __name__ == "__main__":
    main()




