# ============================================================

def validate_dates(context):

    def read_date(file):
        df = pd.read_parquet(DATA_DIR / file)
        return pd.to_datetime(df.iloc[0]["REPTDATE"]).strftime("%d%m%Y")

    expected = context["RDATE"]

    sources = {
        "LOAN": read_date("loan_reptdate.parquet"),
        "DEPOSIT": read_date("deposit_reptdate.parquet"),
