# ============================================================

def derive_reporting_context():

    reptdate = datetime.today().replace(day=1) - timedelta(days=1)

    day = reptdate.day

    if day == 8:
        wk = "1"
        sdd = 1
    elif day == 15:
        wk = "2"
        sdd = 9
    elif day == 22:
        wk = "3"
        sdd = 16
    else:
        wk = "4"
        sdd = 23

    month = reptdate.month
    year = reptdate.year

    return {
        "NOWK": wk,
        "REPTMON": f"{month:02}",
        "REPTYEAR": str(year),
        "RDATE": reptdate.strftime("%d%m%Y"),
    }


# ============================================================
# STEP 2 — VALIDATE EXTRACTION DATES
# ============================================================

def validate_dates(context):

    required_files = [
        "loan_reptdate.parquet",
        "deposit_reptdate.parquet",
        "fd_reptdate.parquet",
        "kapiti1_reptdate.parquet",
        "kapiti2_reptdate.parquet",
        "kapiti3_reptdate.parquet"
    ]

    expected = context["RDATE"]

    for file in required_files:
        df = pd.read_parquet(DATA_DIR / file)
        extracted = pd.to_datetime(df.iloc[0]["REPTDATE"]).strftime("%d%m%Y")

        if extracted != expected:
            raise RuntimeError(
                f"{file} extraction date mismatch: {extracted} != {expected}"
            )

