import pandas as pd
from datetime import datetime, timedelta
import sys

# ============================================================
# CONFIG — map mainframe datasets to file paths
# ============================================================

BNM_REPTDATE_PATH = "data/bnm_reptdate.parquet"
LOAN_REPTDATE_PATH = "data/loan_reptdate.parquet"
DEPOSIT_REPTDATE_PATH = "data/deposit_reptdate.parquet"

# ============================================================
# LOAD REPORT DATE
# ============================================================

bnm = pd.read_parquet(BNM_REPTDATE_PATH)

reptdate = pd.to_datetime(bnm["REPTDATE"].iloc[0])

day = reptdate.day
month = reptdate.month
year = reptdate.year

# ============================================================
# CALCULATE WEEK LOGIC (exact SAS logic)
# ============================================================

if day == 8:
    sdd, wk, wk1 = 1, "1", "4"
elif day == 15:
    sdd, wk, wk1 = 9, "2", "1"
elif day == 22:
    sdd, wk, wk1 = 16, "3", "2"
else:
    sdd, wk, wk1 = 23, "4", "3"

mm1 = month - 1 if wk == "1" else month
if mm1 == 0:
    mm1 = 12

sdate = datetime(year, month, sdd)

# Quarter flag
if month in [3, 6, 9, 12] and day in [30, 31]:
    qtr_flag = "1"
else:
    qtr_flag = "0"

# ============================================================
# LOAD EXTRACTION DATES
# ============================================================

loan = pd.read_parquet(LOAN_REPTDATE_PATH)
deposit = pd.read_parquet(DEPOSIT_REPTDATE_PATH)

loan_date = pd.to_datetime(loan["REPTDATE"].iloc[0])
deposit_date = pd.to_datetime(deposit["REPTDATE"].iloc[0])

# ============================================================
# VALIDATION LOGIC (EXACT SAS BEHAVIOR)
# ============================================================

if loan_date == reptdate and deposit_date == reptdate:

    print("✔ Dates match — downstream jobs should run")

    # In production this would trigger:
    # subprocess.run(["python", "lalwpbbd.py"])
    # subprocess.run(["python", "lalwpbbu.py"])
    # subprocess.run(["python", "lalweirc.py"])

else:
    if loan_date != reptdate:
        print(f"ERROR: Loan extraction not dated {reptdate}")

    if deposit_date != reptdate:
        print(f"ERROR: Deposit extraction not dated {reptdate}")

    print("JOB ABORTED")

    sys.exit(77)

