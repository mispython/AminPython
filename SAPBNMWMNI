curr = pd.read_parquet(CURR_SNAPSHOT)

prev = prev[prev["PRODUCT"].isin(VALID_PRODUCTS)]
curr = curr[curr["PRODUCT"].isin(VALID_PRODUCTS)]

key = ["ACCTNO","NOTENO","SECTORCD"]

merged = pd.merge(prev, curr, on=key, how="outer",
