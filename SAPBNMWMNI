merged.loc[both & (merged["BALANCE_prev"] > merged["BALANCE_curr"]),
           "REPAID"] = merged["BALANCE_prev"] - merged["BALANCE_curr"]

merged.loc[both & (merged["BALANCE_curr"] > merged["BALANCE_prev"]),
           "DISBURSE"] = merged["BALANCE_curr"] - merged["BALANCE_prev"]

merged.loc[merged["BALANCE_curr"].isna(),
           "REPAID"] = merged["BALANCE_prev"]

merged.loc[merged["BALANCE_prev"].isna(),
