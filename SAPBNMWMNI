curr = pd.read_parquet(CURR_SNAPSHOT)

prev = prev[prev["PRODUCT"].isin(VALID_PRODUCTS)]
curr = curr[curr["PRODUCT"].isin(VALID_PRODUCTS)]

key = ["ACCTNO","NOTENO","SECTORCD"]

merged = pd.merge(prev, curr, on=key, how="outer",
                  suffixes=("_prev","_curr"))

merged["DISBURSE"] = 0.0
merged["REPAID"] = 0.0
merged["NOACCT"] = 1

both = merged["BALANCE_prev"].notna() & merged["BALANCE_curr"].notna()

merged.loc[both & (merged["BALANCE_prev"] > merged["BALANCE_curr"]),
           "REPAID"] = merged["BALANCE_prev"] - merged["BALANCE_curr"]

merged.loc[both & (merged["BALANCE_curr"] > merged["BALANCE_prev"]),
           "DISBURSE"] = merged["BALANCE_curr"] - merged["BALANCE_prev"]

merged.loc[merged["BALANCE_curr"].isna(), "REPAID"] = merged["BALANCE_prev"]
merged.loc[merged["BALANCE_prev"].isna(), "DISBURSE"] = merged["BALANCE_curr"]

