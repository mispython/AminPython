import pandas as pd
import numpy as np

# =========================================
# CONFIG — file paths must match JCL inputs
# =========================================

REPTDATE_FILE = "bnm_reptdate.csv"
LOAN_MASTER = "loan_lnnote.csv"
PREV_SNAPSHOT = "loan_prev.csv"
CURR_SNAPSHOT = "loan_curr.csv"

# =========================================
# STEP 1 — READ REPORT DATE
# =========================================

rept = pd.read_csv(REPTDATE_FILE, parse_dates=["REPTDATE"])
rept_date = rept["REPTDATE"].iloc[0]

day = rept_date.day

if day == 8:
    wk = "1"
    wk1 = "4"
elif day == 15:
    wk = "2"
    wk1 = "1"
elif day == 22:
    wk = "3"
    wk1 = "2"
else:
    wk = "4"
    wk1 = "3"

# =========================================
# STEP 2 — LOAD LOAN MASTER
# =========================================

loan = pd.read_csv(LOAN_MASTER)

loan = loan[loan["LOANTYPE"].isin([131, 132, 720, 725])].copy()

# Fix interest amount if missing
mask = loan["INTAMT"] <= 0.01

loan.loc[mask, "INTAMT"] = (
    loan["INTRATE"] * loan["NETPROC"] * loan["NOTETERM"] / 1200
) - loan["INTEARN2"]

loan["TERM"] = np.minimum(loan["NOTETERM"], 12)

loan["EFFFACT"] = (
    100 * loan["TERM"] * loan["INTAMT"]
) / (loan["NOTETERM"] * (loan["NETPROC"] + loan["INTEARN2"]))

loan["EFFAPR"] = (
    loan["NOTETERM"] * loan["EFFFACT"] *
    (300 * loan["TERM"] + loan["NOTETERM"] * loan["EFFFACT"])
) / (
    loan["NOTETERM"]**2 * loan["EFFFACT"] +
    150 * loan["TERM"] * (loan["NOTETERM"] + 1)
)

# =========================================
# STEP 3 — LOAD SNAPSHOTS
# =========================================

prev = pd.read_csv(PREV_SNAPSHOT)
curr = pd.read_csv(CURR_SNAPSHOT)

prev = prev[prev["PRODUCT"].isin([131,132,720,725])]
curr = curr[curr["PRODUCT"].isin([131,132,720,725])]

# =========================================
# STEP 4 — MERGE SNAPSHOTS
# =========================================

key = ["ACCTNO","NOTENO","SECTORCD"]

merged = pd.merge(
    prev,
    curr,
    on=key,
    how="outer",
    suffixes=("_prev","_curr")
)

# =========================================
# STEP 5 — CALCULATE DISBURSE / REPAID
# =========================================

merged["DISBURSE"] = 0
merged["REPAID"] = 0

both = merged["BALANCE_prev"].notna() & merged["BALANCE_curr"].notna()

merged.loc[both & (merged["BALANCE_prev"] > merged["BALANCE_curr"]), "REPAID"] = \
    merged["BALANCE_prev"] - merged["BALANCE_curr"]

merged.loc[both & (merged["BALANCE_curr"] > merged["BALANCE_prev"]), "DISBURSE"] = \
    merged["BALANCE_curr"] - merged["BALANCE_prev"]

only_prev = merged["BALANCE_curr"].isna()
only_curr = merged["BALANCE_prev"].isna()

merged.loc[only_prev, "REPAID"] = merged["BALANCE_prev"]
merged.loc[only_curr, "DISBURSE"] = merged["BALANCE_curr"]

# =========================================
# STEP 6 — MERGE APR
# =========================================

merged = pd.merge(
    merged,
    loan[["ACCTNO","NOTENO","SECTORCD","EFFAPR"]],
    on=key,
    how="left"
)

merged["PRODUCT_WEIGHT"] = merged["DISBURSE"] * merged["EFFAPR"]

# =========================================
# STEP 7 — AGGREGATE BY SECTOR
# =========================================

sector = merged.groupby("SECTORCD").agg({
    "DISBURSE":"sum",
    "PRODUCT_WEIGHT":"sum"
}).reset_index()

sector["WEIGHTED"] = sector["PRODUCT_WEIGHT"] / sector["DISBURSE"]

sector["BNMCODE"] = "673400000" + sector["SECTORCD"].astype(str) + "Y"

# =========================================
# STEP 8 — SAVE OUTPUT
# =========================================

sector.to_csv("bnm_hp01_output.csv", index=False)

# =========================================
# STEP 9 — SMI REPORT
# =========================================

smi_codes = ["66","67","68","69"]

smi = merged[merged["CUSTCD"].astype(str).isin(smi_codes)]

smi_summary = smi.groupby("SECTORCD").agg({
    "DISBURSE":"sum",
    "PRODUCT_WEIGHT":"sum"
}).reset_index()

smi_summary["WEIGHTED"] = smi_summary["PRODUCT_WEIGHT"] / smi_summary["DISBURSE"]

smi_summary.to_csv("bnm_hp01_smi.csv", index=False)

print("EIBWHP01 completed successfully.")

