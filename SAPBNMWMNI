import pandas as pd
from datetime import timedelta

# =====================================================
# STEP 1 — READ HEADER DATE
# =====================================================

with open("deposit_raw.txt") as f:
    header = f.readline()

tbdate = header[105:111]  # position @106 PD6 equivalent
reptdate = pd.to_datetime(tbdate, format="%m%d%y")

xdate = reptdate + timedelta(days=1)

# =====================================================
# STEP 2 — READ FD RECORDS ONLY
# =====================================================

colspecs = [
    (2, 4),     # BANKNO
    (23, 26),   # REPTNO
    (26, 28),   # FMTCODE
    (105, 109), # BRANCH
    (109, 115), # ACCTNO
    (121, 122), # PURPOSE
    (126, 132), # DEPODTE
    (155, 165), # CURBAL
    (203, 205), # ACCTTYPE
]

cols = [
    "BANKNO","REPTNO","FMTCODE","BRANCH",
    "ACCTNO","PURPOSE","DEPODTE","CURBAL","ACCTTYPE"
]

df = pd.read_fwf(
    "deposit_raw.txt",
    colspecs=colspecs,
    names=cols,
    skiprows=1
)

# =====================================================
# STEP 3 — FILTER FD ACCOUNTS
# =====================================================

df = df[
    (df.BANKNO == 33) &
    (df.REPTNO == 4001) &
    (df.FMTCODE.isin([1,2]))
]

# =====================================================
# STEP 4 — SPLIT ISLAMIC VS CONVENTIONAL
# =====================================================

islamic = df[(df.BRANCH >= 3000) & (df.BRANCH <= 3999)]
conventional = df.drop(islamic.index)

# =====================================================
# STEP 5 — SAVE OUTPUT
# =====================================================

islamic.to_parquet("IFD.parquet")
conventional.to_parquet("FD.parquet")

print("FD extraction completed")

